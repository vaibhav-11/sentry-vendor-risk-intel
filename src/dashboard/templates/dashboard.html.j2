    <div id="tab-readme" class="tab-pane">
        <div class="bg-slate-800 rounded-xl p-6 border border-slate-700 max-w-4xl mx-auto space-y-6">
            <div>
                <h2 class="text-lg font-bold text-white border-b border-slate-700 pb-2 flex items-center gap-2">📖 Sentry Engine Operations Blueprint</h2>
                <p class="text-xs text-slate-300 mt-2 leading-relaxed">This analytics control center evaluates third-party and sub-tier supplier risks by monitoring digital data footprints and contract values. Use the tabs below to navigate the core modules:</p>
            </div>
            <div class="grid grid-cols-1 md:grid-cols-2 gap-4 text-xs">
                <div class="bg-slate-900/60 p-3 rounded-lg border border-slate-700">
                    <h4 class="font-bold text-blue-400">🗺️ Supply Chain Map</h4>
                    <p class="text-slate-400 mt-1">An interactive graph displaying your supply chain topology structured in a left-to-right hierarchy. Upstream vendors occupy the left quadrant, your company resides in the center, and downstream distribution vectors flow out toward the right.</p>
                </div>
                <div class="bg-slate-900/60 p-3 rounded-lg border border-slate-700">
                    <h4 class="font-bold text-emerald-400">📊 Financial Impact & Scores</h4>
                    <p class="text-slate-400 mt-1">Provides absolute transparency into your portfolio risks. Click any company's data row to expand its risk scores and verify the specific metrics used to calculate them.</p>
                </div>
                <div class="bg-slate-900/60 p-3 rounded-lg border border-slate-700">
                    <h4 class="font-bold text-purple-400">⚡ Action Playbook & Comm Gen</h4>
                    <p class="text-slate-400 mt-1">Automates risk mitigation workflows. Select any vulnerability flag to review pre-vetted dual-sourcing options and generate contextual outreach correspondence templates.</p>
                </div>
                <div class="bg-slate-900/60 p-3 rounded-lg border border-slate-700">
                    <h4 class="font-bold text-amber-400">✏️ Node Management Registry</h4>
                    <p class="text-slate-400 mt-1">Allows you to expand your network graph manually. Add custom operational entities and link them directly to dependencies across the interactive network array.</p>
                </div>
            </div>
            <div class="pt-4 border-t border-slate-700">
                <h3 class="text-xs font-bold uppercase tracking-wider text-slate-300 mb-2">Composite Score Formulation Models</h3>
                <div class="bg-slate-900 p-4 rounded-xl border border-slate-800 text-xs space-y-2 text-slate-300">
                    <p>• <strong>Financial Parameters (30% Weight):</strong> Evaluates operational liquidity buffers, total debt ratios, and solvency markers via computed Altman Z-Scores.</p>
                    <p>• <strong>Operational Parameters (30% Weight):</strong> Measures single-source delivery paths, business continuity plan coverage, and historical system audit results.</p>
                    <p>• <strong>Compliance Parameters (20% Weight):</strong> Monitors corporate governance metrics, standard certification updates, and SEC disclosure filings.</p>
                    <p>• <strong>Geopolitical Parameters (20% Weight):</strong> Evaluates territory infrastructure risks, regional trade adjustments, and manufacturing concentration factors.</p>
                </div>
            </div>
        </div>
    </div>

    <script>
        let VIS_NODES_ARRAY = {{ vis_nodes_json }};
        let VIS_EDGES_ARRAY = {{ vis_edges_json }};
        let RISK_TABLE_DATA = {{ risk_table_json }};
        const GEOPOLITICAL_WEIGHTS = {{ chart_data_json }};
        const VAULT_DOCUMENTS = {{ uploaded_docs_json }};

        let networkInstance = null;
        let nodesDataSet = new vis.DataSet();
        let edgesDataSet = new vis.DataSet();
        let editingNodeId = null; // CRUD update selection trace register

        function switchTab(name) {
            document.querySelectorAll('.tab-pane').forEach(p => p.classList.remove('active'));
            document.querySelectorAll('.tab-btn').forEach(b => b.classList.remove('active'));
            document.getElementById('tab-' + name).classList.add('active');
            if(event && event.currentTarget) { event.currentTarget.classList.add('active'); }
            if (name === 'map') { renderLeftToRightNetwork(); }
        }

        // ── ENFORCE NATURAL UN-CLUSTERED LEFT-TO-RIGHT SPREAD topologY ──
        function renderLeftToRightNetwork() {
            const container = document.getElementById('network-container');
            nodesDataSet.clear();
            edgesDataSet.clear();

            // Set up x-axis cloud distributions by entity category role
            const structures = VIS_NODES_ARRAY.map((node, idx) => {
                const category = node.group ? node.group.toLowerCase() : '';
                let anchorX = 0;

                if (category === 'target') {
                    anchorX = 0;
                } else if (category === 'supplier') {
                    // Spread suppliers dynamically across distinct horizontal boundaries
                    anchorX = (node.level === 2) ? -520 : -260;
                } else {
                    anchorX = (node.level === 2) ? 520 : 260;
                }
                
                // Introduce mathematical variations to distribute positions smoothly along the Y-axis
                node.x = anchorX + (Math.sin(idx) * 75);
                node.y = (idx * 65) - (VIS_NODES_ARRAY.length * 32) + (Math.cos(idx) * 45);
                return node;
            });

            nodesDataSet.add(structures);
            edgesDataSet.add(VIS_EDGES_ARRAY);

            const dataset = { nodes: nodesDataSet, edges: edgesDataSet };
            const configuration = {
                nodes: { shape: 'dot', shadow: true, physics: true },
                edges: { smooth: { type: 'continuous', roundness: 0.4 }, arrows: "to" },
                physics: {
                    enabled: true,
                    barnesHut: {
                        gravitationalConstant: -4500, // Forces strong horizontal and vertical separation
                        centralGravity: 0.08,
                        springLength: 160,
                        springConstant: 0.05,
                        avoidOverlap: 1
                    },
                    stabilization: { iterations: 120 }
                }
            };

            networkInstance = new vis.Network(container, dataset, configuration);
            networkInstance.on("click", function(params) {
                if (params.nodes.length > 0) { showInspector(params.nodes[0]); }
            });
        }

        function showInspector(id) {
            const node = VIS_NODES_ARRAY.find(n => n.id === id);
            if (!node) return;
            const content = document.getElementById('inspector-content');
            content.classList.remove('hidden');

            let backupsList = (node.meta.backups && node.meta.backups.length > 0) 
                ? node.meta.backups.map(b => `<li class="bg-slate-900 px-2 py-1 border border-slate-700 rounded text-slate-300 text-[11px] font-mono">⚡ ${b}</li>`).join('')
                : `<li class="text-slate-500 italic">No alternative vendors registered</li>`;

            content.innerHTML = `
                <div class="border-b border-slate-700 pb-2">
                    <h4 class="text-md font-bold text-blue-400">${node.meta.name}</h4>
                    <p class="text-[10px] text-slate-400 uppercase font-mono">${node.meta.type} | Sector: ${node.meta.industry}</p>
                </div>
                <div class="grid grid-cols-2 gap-2 text-xs">
                    <div class="bg-slate-900/60 p-2 rounded border border-slate-800">
                        <span class="text-[10px] text-slate-500 uppercase block">Risk Score</span>
                        <strong class="text-sm font-bold text-white">${node.meta.score} / 100</strong>
                    </div>
                    <div class="bg-slate-900/60 p-2 rounded border border-slate-800">
                        <span class="text-[10px] text-slate-500 uppercase block">Calculated VaR</span>
                        <strong class="text-sm font-bold text-red-400">$${node.meta.value_at_risk.toLocaleString()}</strong>
                    </div>
                </div>
                <div>
                    <span class="text-[10px] text-slate-400 font-semibold uppercase block mb-1">Pre-Vetted Contingency Options:</span>
                    <ul class="space-y-1">${backupsList}</ul>
                </div>
            `;
        }

        // ── score TRANSPARENCY CONSOLE MANAGEMENT ──
        function showTransparencyConsole() {
            const tbody = document.getElementById('analytics-table-body');
            tbody.innerHTML = RISK_TABLE_DATA.map(r => `
                <tr onclick="toggleTransparencyDropdown('${r.entity_id}')" class="hover:bg-slate-700/30 transition cursor-pointer border-b border-slate-800">
                    <td class="py-3 pl-2 font-medium text-white flex items-center gap-2">▶ <span class="text-blue-400 hover:underline">${r.name}</span></td>
                    <td class="py-3 uppercase font-mono text-[11px] text-slate-400">${r.type}</td>
                    <td class="py-3 font-mono text-slate-300">${r.country}</td>
                    <td class="py-3"><span class="px-2 py-0.5 rounded text-[11px] font-bold ${r.score >= 65 ? 'bg-red-950 text-red-400 border border-red-900' : 'bg-slate-900 text-emerald-400'}">${r.score}</span></td>
                    <td class="py-3 text-right pr-2 font-mono font-bold text-slate-300">$${r.value_at_risk.toLocaleString()}</td>
                </tr>
                <tr id="dropdown-${r.entity_id}" class="hidden bg-slate-900/50">
                    <td colspan="5" class="p-4">
                        <div class="grid grid-cols-1 md:grid-cols-4 gap-4 text-xs">
                            <div class="bg-slate-900 border border-slate-800 p-3 rounded-lg">
                                <p class="font-bold text-blue-400 mb-1">Financial Data Core (${r.meta.fin_score}/100)</p>
                                <ul class="list-disc pl-4 space-y-1 text-slate-400 text-[11px]">${r.meta.fin_drivers.map(d => `<li>${d}</li>`).join('')}</ul>
                            </div>
                            <div class="bg-slate-900 border border-slate-800 p-3 rounded-lg">
                                <p class="font-bold text-emerald-400 mb-1">Operational Data Core (${r.meta.ops_score}/100)</p>
                                <ul class="list-disc pl-4 space-y-1 text-slate-400 text-[11px]">${r.meta.ops_drivers.map(d => `<li>${d}</li>`).join('')}</ul>
                            </div>
                            <div class="bg-slate-900 border border-slate-800 p-3 rounded-lg">
                                <p class="font-bold text-amber-400 mb-1">Compliance Scope (${r.meta.comp_score}/100)</p>
                                <p class="text-slate-400 text-[11px]">SEC disclosure requirements validated. No open litigation events flags discovered.</p>
                            </div>
                            <div class="bg-slate-900 border border-slate-800 p-3 rounded-lg">
                                <p class="font-bold text-purple-400 mb-1">Geopolitical Scope (${r.meta.geo_score}/100)</p>
                                <p class="text-slate-400 text-[11px]">Territory concentration exposure checked against local sovereign disruption indices.</p>
                            </div>
                        </div>
                    </td>
                </tr>
            `).join('');

            const geoContainer = document.getElementById('geo-distribution-container');
            geoContainer.innerHTML = Object.entries(GEOPOLITICAL_WEIGHTS.geo_distribution).map(([country, percentage]) => `
                <div>
                    <div class="flex justify-between text-xs font-mono mb-1 text-slate-300">
                        <span>Territory Code: <strong>${country}</strong></span>
                        <span>Portfolio Share: ${percentage}%</span>
                    </div>
                    <div class="w-full bg-slate-900 h-2 rounded border border-slate-800 overflow-hidden">
                        <div class="bg-blue-500 h-full" style="width: ${percentage}%"></div>
                    </div>
                </div>
            `).join('');
        }

        function toggleTransparencyDropdown(id) {
            document.getElementById('dropdown-' + id).classList.toggle('hidden');
        }

        // ── REFRESH ENGINE SIMULATOR RUNNER ──
        function triggerPipelineRefresh() {
            const modal = document.getElementById('refresh-modal');
            modal.classList.remove('hidden');

            const steps = ['step-1', 'step-2', 'step-3', 'step-4'];
            steps.forEach((step, idx) => {
                setTimeout(() => {
                    const el = document.getElementById(step);
                    el.classList.remove('text-slate-500');
                    el.classList.add('text-blue-400', 'font-bold');
                    el.textContent = el.textContent.replace('⏳', '✅');
                    if (idx > 0) {
                        const prev = document.getElementById(steps[idx-1]);
                        prev.classList.remove('text-blue-400');
                        prev.classList.add('text-slate-400');
                    }
                }, (idx + 1) * 1100);
            });

            setTimeout(() => {
                modal.classList.add('hidden');
                document.getElementById('generation-timestamp').textContent = new Date().toUTCString().replace('GMT', 'UTC');
                alert("Agentic background assessment fan-out complete!");
            }, 5200);
        }

        // ── COMPREHENSIVE NODE MANIPULATION REGISTRY (ADD & INLINE EDIT CONSOLE) ──
        function renderNodeDirectory() {
            const tbody = document.getElementById('directory-table-body');
            tbody.innerHTML = VIS_NODES_ARRAY.map(n => `
                <tr class="hover:bg-slate-700/20 border-b border-slate-800/60">
                    <td class="py-2.5 font-medium text-white pl-2">${n.label}</td>
                    <td class="py-2.5 font-mono text-slate-400 text-[11px]">${n.id}</td>
                    <td class="py-2.5 uppercase text-slate-400 text-[10px]">${n.group || 'Supplier'}</td>
                    <td class="py-2.5 text-slate-300">${n.meta?.industry || 'General Operations'}</td>
                    <td class="py-2.5 font-mono text-slate-400">${n.meta?.country || 'US'}</td>
                    <td class="py-2.5 text-right pr-2">
                        <button onclick="initiateNodeEdit('${n.id}')" class="px-2.5 py-0.5 bg-amber-600/20 text-amber-400 border border-amber-500/30 rounded text-[11px] font-bold hover:bg-amber-600 hover:text-white transition">✏️ Edit</button>
                    </td>
                </tr>
            `).join('');

            const selector = document.getElementById('form-edge-target');
            selector.innerHTML = VIS_NODES_ARRAY.map(n => `<option value="${n.id}">${n.label} (${n.id})</option>`).join('');
        }

        function initiateNodeEdit(id) {
            const node = VIS_NODES_ARRAY.find(n => n.id === id);
            if (!node) return;

            editingNodeId = id;
            document.getElementById('form-action-title').textContent = `✏️ Edit Workspace Entity: ${node.label}`;
            document.getElementById('form-submit-btn').textContent = "💾 Save Entity Modifications";
            document.getElementById('form-cancel-btn').classList.remove('hidden');
            document.getElementById('form-edge-container').classList.add('hidden'); // Lock relationships structure during properties updates

            // Map variables inside input fields
            document.getElementById('form-node-id').value = node.id;
            document.getElementById('form-node-id').disabled = true;
            document.getElementById('form-node-name').value = node.label;
            document.getElementById('form-node-type').value = node.group;
            document.getElementById('form-node-country').value = node.meta?.country || 'US';
            document.getElementById('form-node-industry').value = node.meta?.industry || 'General Operations';
            document.getElementById('form-node-importance').value = ((node.size - 20) / 3).toFixed(1);
            document.getElementById('form-node-spend').value = node.meta?.value_at_risk || 2500000;
        }

        function handleManualNodeSubmit(event) {
            event.preventDefault();
            const id = document.getElementById('form-node-id').value.trim();
            const name = document.getElementById('form-node-name').value.trim();
            const type = document.getElementById('form-node-type').value;
            const country = document.getElementById('form-node-country').value.trim().toUpperCase();
            const industry = document.getElementById('form-node-industry').value.trim();
            const importance = parseFloat(document.getElementById('form-node-importance').value);
            const spend = parseFloat(document.getElementById('form-node-spend').value);
            const targetEdge = document.getElementById('form-edge-target').value;

            if (editingNodeId) {
                // UPDATE RECORD MODE
                const targetNode = VIS_NODES_ARRAY.find(n => n.id === editingNodeId);
                if (targetNode) {
                    targetNode.label = name;
                    targetNode.group = type;
                    targetNode.size = 20 + (importance * 3);
                    targetNode.title = `Entity: ${name}\nType: ${type.toUpperCase()}\nHQ Region: ${country}\nRisk Score: ${targetNode.meta.score}/100\nValue-at-Risk: $${spend.toLocaleString()}`;
                    
                    targetNode.meta.name = name;
                    targetNode.meta.type = type;
                    targetNode.meta.country = country;
                    targetNode.meta.industry = industry;
                    targetNode.meta.value_at_risk = spend;
                    
                    const matchedTable = RISK_TABLE_DATA.find(r => r.entity_id === editingNodeId);
                    if (matchedTable) {
                        matchedTable.name = name;
                        matchedTable.type = type.toUpperCase();
                        matchedTable.country = country;
                        matchedTable.value_at_risk = spend;
                        matchedTable.meta = targetNode.meta;
                    }
                }
                alert(`Node alterations successfully stored!`);
                resetNodeForm();
            } else {
                // INSERT NEW RECORD MODE
                if (VIS_NODES_ARRAY.some(n => n.id === id)) {
                    alert("An entity with this code prefix identifier already exists.");
                    return;
                }

                const mockNode = {
                    id: id, label: name,
                    title: `Entity: ${name}\nType: ${type.toUpperCase()}\nHQ Region: ${country}\nRisk Score: 45.0/100\nValue-at-Risk: $${spend.toLocaleString()}`,
                    color: { background: '#3b82f6', border: '#0f172a' },
                    size: 20 + (importance * 3),
                    font: { color: '#f8fafc', size: 12 },
                    group: type, level: 1,
                    meta: {
                        entity_id: id, name: name, ticker: "—", type: type, industry: industry, country: country,
                        depth: 1, score: 45.0, risk_level: "medium", narrative: "Manually registered sourcing component asset.",
                        fin_score: 50.0, ops_score: 50.0, comp_score: 50.0, geo_score: 50.0, value_at_risk: spend,
                        backups: [], fin_drivers: ["Manual data insertion baseline"], ops_drivers: ["Awaiting document execution audit"]
                    }
                };

                VIS_NODES_ARRAY.push(mockNode);
                VIS_EDGES_ARRAY.push({ from: id, to: targetEdge, label: "supplies_component", width: 2, color: { color: '#64748b' }, arrows: "to" });
                
                RISK_TABLE_DATA.push({
                    entity_id: id, name: name, ticker: "—", type: type.toUpperCase(), country: country,
                    score: 45.0, level: "medium", fin: 50.0, ops: 50.0, comp: 50.0, geo: 50.0, value_at_risk: spend, meta: mockNode.meta
                });

                alert(`Node "${name}" successfully compiled and injected!`);
                document.getElementById('add-node-form').reset();
            }

            renderNodeDirectory();
            showTransparencyConsole();
            switchTab('map');
        }

        function resetNodeForm() {
            editingNodeId = null;
            document.getElementById('form-action-title').textContent = "Add New Supply Chain Entity";
            document.getElementById('form-submit-btn').textContent = "➕ Inject Node Into Live Topography";
            document.getElementById('form-cancel-btn').classList.add('hidden');
            document.getElementById('form-edge-container').classList.remove('hidden');
            document.getElementById('form-node-id').disabled = false;
            document.getElementById('add-node-form').reset();
        }

        const COMPILATION_SCHEDULER = [
            { id: 1, title: "Mitigate Single-Source Value-at-Risk Vector", subject: "Strategic Sourcing Evaluation & Continuity Protocol Request", body: "Dear Sourcing Operations Team,\n\nOur system has identified a single-source configuration tracking above normal threshold metrics.\n\nTo ensure supply chain stabilization, please deliver your regional continuity matrix or asset isolation blueprint plans within 5 business days.\n\nBest Regards,\nStrategic Procurement and Risk Operations Center" },
            { id: 2, title: "Resolve Open Compliance Validation Gap", subject: "Mandatory Corporate Governance Certification Update Notice", body: "Dear Business Partner,\n\nOur automated verification pipeline has identified an outstanding documentation refresh requirement linked to your governance file.\n\nPlease upload your updated entity compliance certificates directly to our workspace vault portal immediately to ensure uninterrupted transactions.\n\nBest Regards,\nCorporate Sourcing Governance & Audit Review Board" }
        ];

        function renderPlaybooks() {
            document.getElementById('playbook-trigger-list').innerHTML = COMPILATION_SCHEDULER.map(p => `
                <button onclick="activatePlaybook(${p.id})" class="w-full text-left p-3 bg-slate-900 text-xs font-semibold rounded-lg border border-slate-700 hover:border-blue-500 hover:bg-slate-900/80 transition block text-slate-300">
                    ⚡ ${p.title}
                </button>
            `).join('');
        }

        function activatePlaybook(id) {
            const playbook = COMPILATION_SCHEDULER.find(p => p.id === id);
            document.getElementById('comm-subject').textContent = playbook.subject;
            document.getElementById('comm-body').value = playbook.body;
        }

        function copyCommMessage() {
            navigator.clipboard.writeText(document.getElementById('comm-body').value);
            alert("Communications script copied to system clipboard memory!");
        }

        function renderDataRoom() {
            document.getElementById('dataroom-list').innerHTML = VAULT_DOCUMENTS.map(d => `
                <div class="flex justify-between items-center bg-slate-900 p-3 rounded-lg border border-slate-800 text-xs">
                    <div class="flex items-center gap-3">
                        <span class="text-lg">📄</span>
                        <div>
                            <p class="font-bold text-slate-200">${d.name} <span class="font-mono text-[10px] text-slate-500">(${d.size})</span></p>
                            <p class="text-[10px] text-slate-400 mt-0.5">Classification Type: <strong>${d.type}</strong></p>
                        </div>
                    </div>
                    <div class="text-right">
                        <span class="px-2 py-0.5 rounded text-[10px] font-bold bg-blue-950 text-blue-400 border border-blue-900">Vectorized & Active via RAG</span>
                        <p class="text-[9px] text-slate-500 mt-1">Associated Nodes: ${d.linked_nodes.join(', ')}</p>
                    </div>
                </div>
            `).join('');
        }

        window.onload = function() {
            renderLeftToRightNetwork();
            showTransparencyConsole();
            renderPlaybooks();
            renderDataRoom();
            renderNodeDirectory();
        };
    </script>
</body>
</html>