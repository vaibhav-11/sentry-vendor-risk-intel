    <div id="tab-dataroom" class="tab-pane">
        <div class="bg-slate-800 rounded-xl p-6 border border-slate-700 shadow-lg max-w-5xl mx-auto">
            <div class="flex items-start gap-4 border-b border-slate-700 pb-4 mb-4">
                <div class="p-3 bg-blue-900/30 rounded-lg border border-blue-500/30 text-xl">🏢</div>
                <div>
                    <h2 class="text-md font-bold text-white">Document Processing Repository</h2>
                    <p class="text-xs text-slate-400 mt-0.5">Manage and organize ingested statements of work, master service agreements, and vendor transaction records.</p>
                </div>
            </div>
            <div class="border-2 border-dashed border-slate-600 hover:border-blue-500 rounded-xl p-8 text-center bg-slate-900/50 transition mb-6 cursor-pointer" onclick="alert('File browser invocation triggered.')">
                <span class="text-2xl">📥</span>
                <h4 class="text-sm font-semibold text-slate-200 mt-2">Upload Enterprise Supply Chain Documents</h4>
                <p class="text-xs text-slate-500 mt-1">Supported file formats: PDF, CSV, XLSX, DOCX. Uploaded documents are automatically mapped to network graph nodes.</p>
            </div>
            <h3 class="text-xs font-bold uppercase tracking-wider text-blue-400 mb-3">Linked Vector Embeddings</h3>
            <div class="space-y-2" id="dataroom-list"></div>
        </div>
    </div>

    <div id="tab-nodemgmt" class="tab-pane">
        <div class="grid grid-cols-1 lg:grid-cols-3 gap-6">
            <div class="lg:col-span-1 bg-slate-800 rounded-xl p-4 border border-slate-700 space-y-4">
                <h3 id="form-action-title" class="text-sm font-bold uppercase tracking-wider text-slate-200">Add New Supply Chain Entity</h3>
                <form id="add-node-form" onsubmit="handleManualNodeSubmit(event)" class="space-y-3 text-xs">
                    <div>
                        <label class="block text-slate-400 mb-1">Unique Identifier ID (Slug)</label>
                        <input type="text" id="form-node-id" placeholder="e.g., asml-sub-de" class="w-full bg-slate-900 border border-slate-700 p-2 rounded text-slate-100 focus:border-blue-500 focus:outline-none disabled:bg-slate-950 disabled:text-slate-500" required>
                    </div>
                    <div>
                        <label class="block text-slate-400 mb-1">Company Display Name</label>
                        <input type="text" id="form-node-name" placeholder="e.g., ASML Subcomponents GmbH" class="w-full bg-slate-900 border border-slate-700 p-2 rounded text-slate-100 focus:border-blue-500 focus:outline-none" required>
                    </div>
                    <div>
                        <label class="block text-slate-400 mb-1">Supply Chain Category Classification</label>
                        <select id="form-node-type" class="w-full bg-slate-900 border border-slate-700 p-2 rounded text-slate-100 focus:border-blue-500 focus:outline-none">
                            <option value="supplier">Supplier (Upstream Supply Chain)</option>
                            <option value="customer">Customer (Downstream Channels)</option>
                            <option value="partner">Strategic Alliance / Partner</option>
                        </select>
                    </div>
                    <div class="grid grid-cols-2 gap-2">
                        <div>
                            <label class="block text-slate-400 mb-1">HQ Country Code</label>
                            <input type="text" id="form-node-country" placeholder="DE" class="w-full bg-slate-900 border border-slate-700 p-2 rounded text-slate-100 focus:border-blue-500 focus:outline-none" required>
                        </div>
                        <div>
                            <label class="block text-slate-400 mb-1">Industry Sector</label>
                            <input type="text" id="form-node-industry" placeholder="Semiconductors" class="w-full bg-slate-900 border border-slate-700 p-2 rounded text-slate-100 focus:border-blue-500 focus:outline-none" required>
                        </div>
                    </div>
                    <div class="grid grid-cols-2 gap-2">
                        <div>
                            <label class="block text-slate-400 mb-1">Importance (1-10)</label>
                            <input type="number" id="form-node-importance" min="1" max="10" step="0.1" value="5.0" class="w-full bg-slate-900 border border-slate-700 p-2 rounded text-slate-100 focus:border-blue-500 focus:outline-none">
                        </div>
                        <div>
                            <label class="block text-slate-400 mb-1">Annual Spend ($)</label>
                            <input type="number" id="form-node-spend" value="2500000" class="w-full bg-slate-900 border border-slate-700 p-2 rounded text-slate-100 focus:border-blue-500 focus:outline-none">
                        </div>
                    </div>
                    <div id="form-edge-container" class="pt-2 border-t border-slate-700">
                        <label class="block text-amber-400 font-semibold mb-1">Connect Network Dependency Edge to:</label>
                        <select id="form-edge-target" class="w-full bg-slate-900 border border-slate-700 p-2 rounded text-slate-100 focus:border-blue-500 focus:outline-none"></select>
                    </div>
                    <div class="pt-2">
                        <label class="block text-slate-400 mb-1">Attach SOW / RAG Context Artifact</label>
                        <input type="file" class="text-xs text-slate-400 file:mr-2 file:py-1 file:px-2 file:rounded file:border-0 file:bg-slate-700 file:text-slate-200 hover:file:bg-slate-600 cursor-pointer">
                    </div>
                    <button type="submit" id="form-submit-btn" class="w-full py-2 bg-blue-600 hover:bg-blue-500 text-white font-bold rounded transition mt-3">➕ Inject Node Into Live Topography</button>
                    <button type="button" id="form-cancel-btn" onclick="resetNodeForm()" class="w-full py-1.5 bg-slate-700 hover:bg-slate-600 text-slate-300 font-medium rounded transition mt-2 hidden">Cancel Workspace Edit</button>
                </form>
            </div>
            <div class="lg:col-span-2 bg-slate-800 rounded-xl p-4 border border-slate-700">
                <h3 class="text-sm font-bold uppercase tracking-wider text-slate-400 mb-3">Supply Chain Entity Directory</h3>
                <div class="overflow-y-auto max-h-[480px]">
                    <table class="w-full text-left text-xs">
                        <thead>
                            <tr class="border-b border-slate-700 text-slate-400">
                                <th class="pb-2">Entity Name</th>
                                <th class="pb-2">ID Slug</th>
                                <th class="pb-2">Category</th>
                                <th class="pb-2">Sector</th>
                                <th class="pb-2">Region</th>
                                <th class="pb-2 text-right pr-2">Workspace Controls</th>
                            </tr>
                        </thead>
                        <tbody id="directory-table-body" class="divide-y divide-slate-700/40 text-slate-300"></tbody>
                    </table>
                </div>
            </div>
