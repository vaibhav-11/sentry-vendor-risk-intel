                <div class="space-y-3 mt-4" id="geo-distribution-container"></div>
            </div>
        </div>
    </div>

    <div id="tab-playbook" class="tab-pane">
        <div class="grid grid-cols-1 lg:grid-cols-3 gap-6">
            <div class="lg:col-span-1 bg-slate-800 rounded-xl p-4 border border-slate-700 space-y-3">
                <h3 class="text-sm font-bold uppercase tracking-wider text-slate-200">Active Procurement Playbooks</h3>
                <div id="playbook-trigger-list" class="space-y-2"></div>
            </div>
            <div class="lg:col-span-2 bg-slate-800 rounded-xl p-4 border border-slate-700 flex flex-col justify-between">
                <div>
                    <h3 class="text-sm font-bold uppercase tracking-wider text-slate-200 mb-2">Automated Supplier Communication Workspace</h3>
                    <div class="bg-slate-900 border border-slate-700 rounded-xl p-3">
                        <div class="flex justify-between items-center text-xs text-slate-400 border-b border-slate-800 pb-2 mb-2">
