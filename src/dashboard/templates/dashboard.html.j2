<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title>Sentry Vendor Risk Intel Center - {{ target_company }}</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <script type="text/javascript" src="https://unpkg.com/vis-network/standalone/umd/vis-network.min.js"></script>
    <script src="https://cdn.plot.ly/plotly-2.30.0.min.js"></script>
    <style>
        .tab-pane { display: none; }
        .tab-pane.active { display: block; }
        .tab-btn.active { background-color: #1e293b; border-color: #3b82f6; color: #3b82f6; }
        body { background-color: #0f172a; color: #f1f5f9; font-family: system-ui, -apple-system, sans-serif; }
    </style>
</head>
<body class="p-6">

    <div id="freshness-modal" class="fixed inset-0 bg-slate-950/80 backdrop-blur-sm z-50 hidden flex items-center justify-center" onclick="if(event.target===this)this.classList.add('hidden')">
        <div class="bg-slate-900 border border-slate-700 p-6 rounded-xl max-w-lg w-full shadow-2xl max-h-[80vh] overflow-y-auto">
            <div class="flex items-center justify-between mb-4 border-b border-slate-700 pb-3">
                <h3 class="font-bold text-white text-sm">Data Freshness & Change Log</h3>
                <button onclick="document.getElementById('freshness-modal').classList.add('hidden')" class="text-slate-400 hover:text-white text-lg leading-none">×</button>
            </div>
            <div class="mb-5">
                <h4 class="text-xs font-bold uppercase tracking-wider text-slate-400 mb-2">Source Retrieval Timestamps</h4>
                <div id="freshness-sources" class="space-y-1.5 text-xs"></div>
            </div>
            <div>
                <h4 class="text-xs font-bold uppercase tracking-wider text-slate-400 mb-2">Change Since Last Cached Run</h4>
                <div id="freshness-deltas" class="space-y-1.5 text-xs"></div>
            </div>
        </div>
    </div>

    <div class="flex justify-between items-center mb-6 border-b border-slate-700 pb-4">
        <div>
            <h1 class="text-2xl font-bold tracking-tight text-white">🛡️ Sentry Vendor Risk Intelligence Studio</h1>
            <p class="text-xs text-slate-400">Target Ecosystem: <span class="font-semibold text-blue-400">{{ target_company }}</span> | Run: {{ run_id }} | Generated: <span id="generation-timestamp">{{ generated_at }}</span></p>
        </div>
        <div>
            <button onclick="openFreshnessPanel()" class="px-4 py-2 bg-slate-800 border border-slate-600 hover:border-blue-500 text-xs font-bold text-slate-200 rounded-lg shadow transition flex items-center gap-2">
                Data Freshness & Changes
            </button>
        </div>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-4 gap-4 mb-6">
        <div onclick="cardOpenPortfolioValue()" class="bg-slate-800 p-4 rounded-xl border border-slate-700 shadow-sm cursor-pointer hover:border-blue-500 transition group">
            <p class="text-xs text-slate-400 font-medium uppercase tracking-wider group-hover:text-blue-400 transition">Total Portfolio Value</p>
            <h3 class="text-xl font-bold text-white mt-1">{{ stats.total_portfolio_value_abbr }}</h3>
            <p class="text-[11px] text-slate-500 mt-0.5">Click to view the register sorted by contract value ↗</p>
        </div>
        <div onclick="cardOpenVaR()" class="bg-slate-800 p-4 rounded-xl border border-slate-700 shadow-sm cursor-pointer hover:border-red-500 transition group">
            <p class="text-xs text-slate-400 font-medium uppercase tracking-wider group-hover:text-red-400 transition">Portfolio Value-at-Risk</p>
            <h3 class="text-xl font-bold text-red-400 mt-1">{{ stats.total_value_at_risk_abbr }}</h3>
            <p class="text-[11px] text-red-500/80 mt-0.5">Click to sort the register by exposure ↗</p>
        </div>
        <div onclick="cardOpenHHI()" class="bg-slate-800 p-4 rounded-xl border border-slate-700 shadow-sm cursor-pointer hover:border-amber-500 transition group">
            <p class="text-xs text-slate-400 font-medium uppercase tracking-wider group-hover:text-amber-400 transition">Geopolitical HHI Score</p>
            <h3 class="text-xl font-bold text-amber-400 mt-1">{{ stats.geo_concentration_hhi }}</h3>
            <p class="text-[11px] text-slate-500 mt-0.5">Click to jump to the regional-concentration chart ↗</p>
        </div>
        <div onclick="cardOpenNodes()" class="bg-slate-800 p-4 rounded-xl border border-slate-700 shadow-sm cursor-pointer hover:border-indigo-500 transition group">
            <p class="text-xs text-slate-400 font-medium uppercase tracking-wider group-hover:text-indigo-400 transition">Supply Chain Nodes</p>
            <h3 class="text-xl font-bold text-white mt-1">{{ stats.total_entities }} Assets <span class="text-xs font-normal text-red-400">({{ stats.spof_count }} SPOFs)</span></h3>
            <p class="text-[11px] text-slate-500 mt-0.5">Click to focus the network graph ↗</p>
        </div>
    </div>

    <div class="flex gap-2 mb-4 border-b border-slate-700 pb-px">
        <button class="tab-btn active px-4 py-2 text-sm font-semibold border-b-2 border-transparent text-slate-300 hover:text-white" onclick="switchTab('map')">Network</button>
        <button class="tab-btn px-4 py-2 text-sm font-semibold border-b-2 border-transparent text-slate-300 hover:text-white" onclick="switchTab('analytics')">Risk Analysis</button>
        <button class="tab-btn px-4 py-2 text-sm font-semibold border-b-2 border-transparent text-slate-300 hover:text-white" onclick="switchTab('playbook')">Playbooks</button>
        <button class="tab-btn px-4 py-2 text-sm font-semibold border-b-2 border-transparent text-slate-300 hover:text-white" onclick="switchTab('dataroom')">Documents</button>
        <button class="tab-btn px-4 py-2 text-sm font-semibold border-b-2 border-transparent text-slate-300 hover:text-white" onclick="switchTab('nodemgmt')">Manage</button>
        <button class="tab-btn px-4 py-2 text-sm font-semibold border-b-2 border-transparent text-blue-400 hover:text-blue-300 bg-blue-950/20 border border-blue-900 rounded-t-md" onclick="switchTab('readme')">Guide</button>
    </div>

    <div id="tab-map" class="tab-pane active">
        <div class="grid grid-cols-1 lg:grid-cols-3 gap-4">
            <div class="lg:col-span-2 bg-slate-800 rounded-xl p-4 border border-slate-700 h-[580px]" id="network-container"></div>
            <div class="bg-slate-800 rounded-xl p-4 border border-slate-700 h-[580px] flex flex-col" id="node-inspector-panel">
                <div class="flex items-baseline justify-between mb-2 border-b border-slate-700 pb-2">
                    <h3 class="text-sm font-bold text-white">Vendor Inspector</h3>
                    <span id="inspector-header" class="text-[10px] text-slate-400 uppercase font-mono"></span>
                </div>
                <div id="inspector-narrative" class="flex-1 overflow-y-auto">
                    <p class="text-xs text-slate-400">Click any node in the left-to-right network graph to read its AI risk narrative here, with the full dimension breakdown, alternatives, and cited sources in the cards below.</p>
                </div>
            </div>
        </div>
        <!-- On node click these six cards fill the space beneath the graph + narrative. -->
        <div id="inspector-cards" class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4 mt-4"></div>
    </div>

    <div id="tab-analytics" class="tab-pane">
        <div class="grid grid-cols-1 lg:grid-cols-3 gap-6">
            <div class="lg:col-span-2 bg-slate-800 rounded-xl p-4 border border-slate-700">
                <h3 class="text-sm font-bold uppercase tracking-wider text-slate-400 mb-1">Vendor Risk Register</h3>
                <p class="text-xs text-slate-500 mb-4">Click a column header to sort; use the dropdowns to filter by Category, HQ, or Sector. Contract Value (impact) is independent of Composite risk (probability) — a high-contract lesser-known vendor can outrank a low-contract major brand. Click any row to drill into the risk drivers.</p>
                <table class="w-full text-left text-xs text-slate-200">
                    <thead>
                        <tr class="border-b border-slate-700 text-slate-400 font-semibold">
                            <th class="pb-2 pl-2 cursor-pointer hover:text-white select-none" onclick="sortAnalytics('name')">Vendor</th>
                            <th class="pb-2 cursor-pointer hover:text-white select-none" onclick="sortAnalytics('type')">Category</th>
                            <th class="pb-2 cursor-pointer hover:text-white select-none" onclick="sortAnalytics('country')">HQ</th>
                            <th class="pb-2 cursor-pointer hover:text-white select-none" onclick="sortAnalytics('industry')">Sector</th>
                            <th class="pb-2 cursor-pointer hover:text-white select-none" onclick="sortAnalytics('score')">Risk Score</th>
                            <th id="th-contract-value" class="pb-2 text-right cursor-pointer hover:text-white select-none rounded transition" onclick="sortAnalytics('annual_spend_usd')">Contract Value</th>
                            <th class="pb-2 text-right cursor-pointer hover:text-white select-none" onclick="sortAnalytics('dependence_pct')">Dependence&nbsp;%</th>
                            <th id="th-exposure" class="pb-2 text-right pr-2 cursor-pointer hover:text-white select-none rounded transition" onclick="sortAnalytics('value_at_risk')">Exposure</th>
                        </tr>
                        <tr class="border-b border-slate-700/60 text-[10px]">
                            <th class="pb-2 pl-2"></th>
                            <th class="pb-2 pr-2"><select id="filter-type" onchange="applyAnalyticsFilters()" class="w-full bg-slate-900 border border-slate-700 rounded px-1 py-0.5 text-slate-300 text-[10px] focus:outline-none focus:border-blue-500"></select></th>
                            <th class="pb-2 pr-2"><select id="filter-country" onchange="applyAnalyticsFilters()" class="w-full bg-slate-900 border border-slate-700 rounded px-1 py-0.5 text-slate-300 text-[10px] focus:outline-none focus:border-blue-500"></select></th>
                            <th class="pb-2 pr-2"><select id="filter-industry" onchange="applyAnalyticsFilters()" class="w-full bg-slate-900 border border-slate-700 rounded px-1 py-0.5 text-slate-300 text-[10px] focus:outline-none focus:border-blue-500"></select></th>
                            <th class="pb-2" colspan="4"></th>
                        </tr>
                    </thead>
                    <tbody id="analytics-table-body" class="divide-y divide-slate-700/40"></tbody>
                </table>
            </div>
            <div class="bg-slate-800 rounded-xl p-4 border border-slate-700 self-start">
                <h3 class="text-sm font-bold uppercase tracking-wider text-slate-400 mb-3">Regional Concentration Breakdown</h3>
                <div class="space-y-2" id="geo-distribution-container"></div>
            </div>
        </div>

        <div class="mt-6 bg-slate-800 rounded-xl p-4 border border-slate-700">
            <h3 class="text-sm font-bold uppercase tracking-wider text-slate-400 mb-1">Impact &times; Probability Exposure Matrix</h3>
            <p class="text-xs text-slate-500 mb-3">X = vendor composite risk (probability of disruption) &middot; Y = annual contract spend (impact) &middot; bubble size &amp; colour = Value-at-Risk. Top-right is the danger quadrant: high spend <em>and</em> high risk. This is why a large-contract vendor with a moderate score can carry more portfolio VaR than a low-contract, high-score one.</p>
            <div id="exposure-scatter" style="width:100%;height:440px;"></div>
        </div>
    </div>

    <div id="tab-playbook" class="tab-pane">
        <div class="grid grid-cols-1 lg:grid-cols-3 gap-6">
            <div class="lg:col-span-1 bg-slate-800 rounded-xl p-4 border border-slate-700 space-y-3">
                <h3 class="text-sm font-bold uppercase tracking-wider text-slate-200">Risk Playbooks</h3>
                <p class="text-[11px] text-slate-500">Ranked by severity — every vendor with discernible risk. Select one to draft outreach.</p>
                <div id="playbook-trigger-list" class="space-y-2 max-h-[520px] overflow-y-auto pr-1"></div>
            </div>
            <div class="lg:col-span-2 bg-slate-800 rounded-xl p-4 border border-slate-700 flex flex-col justify-between">
                <div>
                    <h3 class="text-sm font-bold uppercase tracking-wider text-slate-200 mb-2">Outreach Generator</h3>
                    <div class="bg-slate-900 border border-slate-700 rounded-xl p-3">
                        <div class="flex justify-between items-center text-xs text-slate-400 border-b border-slate-800 pb-2 mb-2">
                            <div><strong>Subject Line:</strong> <span id="comm-subject" class="text-blue-400">Select a playbook item...</span></div>
                        </div>
                        <textarea id="comm-body" class="w-full h-64 bg-transparent text-slate-200 font-mono text-xs focus:outline-none resize-none" readonly>Select an active alert playbook from the sidebar to compile contextual messaging content...</textarea>
                    </div>
                </div>
                <div class="mt-4 pt-3 border-t border-slate-700 flex justify-end">
                    <button onclick="copyCommMessage()" class="px-4 py-2 bg-blue-600 hover:bg-blue-500 text-xs font-bold text-white rounded transition shadow-sm">📋 Copy Communications Package to Clipboard</button>
                </div>
            </div>
        </div>
    </div>

    <div id="tab-dataroom" class="tab-pane">
        <div class="bg-slate-800 rounded-xl p-6 border border-slate-700 shadow-lg max-w-5xl mx-auto">
            <div class="flex items-start gap-4 border-b border-slate-700 pb-4 mb-4">
                <div class="p-3 bg-blue-900/30 rounded-lg border border-blue-500/30 text-xl">🏢</div>
                <div>
                    <h2 class="text-sm font-bold text-white">Document Data Room</h2>
                    <p class="text-xs text-slate-400 mt-1">Contract ingestion maps Master Service Agreements and SOWs to the supply-chain graph. The documents below are linked to real nodes from this run.</p>
                </div>
            </div>
            <div onclick="showComingSoon('Document upload &amp; RAG ingestion')" class="border-2 border-dashed border-slate-700 rounded-xl p-8 text-center bg-slate-900/50 mb-6 cursor-pointer hover:border-blue-500 transition group">
                <span class="text-2xl">📥</span>
                <h4 class="text-sm font-semibold text-slate-300 mt-2 group-hover:text-blue-400 transition">Upload Enterprise Supply Chain Documents</h4>
                <p class="text-xs text-slate-500 mt-1">PDF, CSV, XLSX, DOCX ingestion mapped to network graph nodes. Click to learn more.</p>
            </div>
            <h3 class="text-xs font-bold uppercase tracking-wider text-slate-400 mb-3">Linked Documents (mapped to live nodes)</h3>
            <div class="space-y-2" id="dataroom-list"></div>
        </div>
    </div>

    <div id="tab-nodemgmt" class="tab-pane">
        <div class="grid grid-cols-1 lg:grid-cols-3 gap-6">
            <div class="lg:col-span-1 bg-slate-800 rounded-xl p-4 border border-slate-700 space-y-4">
                <h3 id="form-action-title" class="text-sm font-bold uppercase tracking-wider text-slate-200">Add New Supply Chain Entity</h3>
                <form id="add-node-form" onsubmit="handleManualNodeSubmit(event)" class="space-y-3 text-xs">
                    <div>
                        <label class="block text-slate-400 mb-1">Unique Identifier ID (Slug)</label>
                        <input type="text" id="form-node-id" placeholder="e.g., asml-sub-de" class="w-full bg-slate-900 border border-slate-700 p-2 rounded text-slate-100 focus:border-blue-500 focus:outline-none disabled:bg-slate-950 disabled:text-slate-500" required>
                    </div>
                    <div>
                        <label class="block text-slate-400 mb-1">Company Display Name</label>
                        <input type="text" id="form-node-name" placeholder="e.g., ASML Subcomponents GmbH" class="w-full bg-slate-900 border border-slate-700 p-2 rounded text-slate-100 focus:border-blue-500 focus:outline-none" required>
                    </div>
                    <div>
                        <label class="block text-slate-400 mb-1">Supply Chain Category Classification</label>
                        <select id="form-node-type" class="w-full bg-slate-900 border border-slate-700 p-2 rounded text-slate-100 focus:border-blue-500 focus:outline-none">
                            <option value="supplier">Supplier (Upstream Supply Chain)</option>
                            <option value="partner">Strategic Alliance / Partner</option>
                            <option value="logistics">Logistics Provider</option>
                        </select>
                    </div>
                    <div class="grid grid-cols-2 gap-2">
                        <div>
                            <label class="block text-slate-400 mb-1">HQ Country Code</label>
                            <input type="text" id="form-node-country" placeholder="DE" class="w-full bg-slate-900 border border-slate-700 p-2 rounded text-slate-100 focus:border-blue-500 focus:outline-none" required>
                        </div>
                        <div>
                            <label class="block text-slate-400 mb-1">Industry Sector</label>
                            <input type="text" id="form-node-industry" placeholder="Semiconductors" class="w-full bg-slate-900 border border-slate-700 p-2 rounded text-slate-100 focus:border-blue-500 focus:outline-none" required>
                        </div>
                    </div>
                    <div class="grid grid-cols-2 gap-2">
                        <div>
                            <label class="block text-slate-400 mb-1">Importance (1-10)</label>
                            <input type="number" id="form-node-importance" min="1" max="10" step="0.1" value="5.0" class="w-full bg-slate-900 border border-slate-700 p-2 rounded text-slate-100 focus:border-blue-500 focus:outline-none">
                        </div>
                        <div>
                            <label class="block text-slate-400 mb-1">Annual Spend ($)</label>
                            <input type="number" id="form-node-spend" value="2500000" class="w-full bg-slate-900 border border-slate-700 p-2 rounded text-slate-100 focus:border-blue-500 focus:outline-none">
                        </div>
                    </div>
                    <div id="form-edge-container" class="pt-2 border-t border-slate-700">
                        <label class="block text-amber-400 font-semibold mb-1">Connect Network Dependency Edge to:</label>
                        <select id="form-edge-target" class="w-full bg-slate-900 border border-slate-700 p-2 rounded text-slate-100 focus:border-blue-500 focus:outline-none"></select>
                    </div>
                    <div class="pt-2">
                        <label class="block text-slate-400 mb-1">Attach SOW / RAG Context Artifact</label>
                        <button type="button" onclick="showComingSoon('Document attach &amp; RAG context')" class="text-xs text-slate-300 bg-slate-700 hover:bg-slate-600 px-3 py-1.5 rounded transition">Choose File…</button>
                    </div>
                    <button type="submit" id="form-submit-btn" class="w-full py-2 bg-blue-600 hover:bg-blue-500 text-white font-bold rounded transition mt-3">➕ Inject Node Into Live Topography</button>
                    <button type="button" id="form-cancel-btn" onclick="resetNodeForm()" class="w-full py-1.5 bg-slate-700 hover:bg-slate-600 text-slate-300 font-medium rounded transition mt-2 hidden">Cancel Workspace Edit</button>
                </form>
            </div>
            <div class="lg:col-span-2 bg-slate-800 rounded-xl p-4 border border-slate-700">
                <h3 class="text-sm font-bold uppercase tracking-wider text-slate-400 mb-3">Supply Chain Entity Directory</h3>
                <div class="overflow-y-auto max-h-[480px]">
                    <table class="w-full text-left text-xs">
                        <thead>
                            <tr class="border-b border-slate-700 text-slate-400">
                                <th class="pb-2">Entity Name</th>
                                <th class="pb-2">ID Slug</th>
                                <th class="pb-2">Category</th>
                                <th class="pb-2">Sector</th>
                                <th class="pb-2">Region</th>
                                <th class="pb-2 text-right pr-2">Workspace Controls</th>
                            </tr>
                        </thead>
                        <tbody id="directory-table-body" class="divide-y divide-slate-700/40 text-slate-300"></tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>

    <div id="tab-readme" class="tab-pane">
        <div class="w-full space-y-6">

            <!-- Header -->
            <div class="bg-slate-800 rounded-xl p-6 border border-slate-700">
                <h2 class="text-sm font-bold uppercase tracking-wider text-white mb-1">Sentry — Vendor Risk Intelligence</h2>
                <p class="text-xs text-slate-400 leading-relaxed">Sentry maps a target company's supply chain across multiple tiers, aggregates financial, operational, compliance, and geopolitical signals from live public sources, and scores each vendor across four weighted dimensions. Every score on this dashboard is traceable to a cited, timestamped source. Click any node in the Network tab to see the full evidence breakdown.</p>
            </div>

            <!-- Dashboard tabs -->
            <div class="bg-slate-800 rounded-xl p-6 border border-slate-700">
                <h3 class="text-xs font-bold uppercase tracking-wider text-slate-300 mb-4">Dashboard Tabs</h3>
                <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-3 text-xs">
                    <div class="bg-slate-900/60 p-4 rounded-lg border border-slate-700">
                        <h4 class="font-semibold text-blue-400 mb-1">Network</h4>
                        <p class="text-slate-400 leading-relaxed">Left-to-right supply graph: suppliers and partners on the left, the target on the right. Node size = contract spend; ring colour = risk band; ring thickness = exposure. SPOFs are dashed. Click a node to inspect it.</p>
                    </div>
                    <div class="bg-slate-900/60 p-4 rounded-lg border border-slate-700">
                        <h4 class="font-semibold text-emerald-400 mb-1">Risk Analysis</h4>
                        <p class="text-slate-400 leading-relaxed">Sortable, filterable vendor register; expand a row for the four dimension drivers. The impact × probability scatter and regional-HHI chart show where spend and risk concentrate.</p>
                    </div>
                    <div class="bg-slate-900/60 p-4 rounded-lg border border-slate-700">
                        <h4 class="font-semibold text-purple-400 mb-1">Playbooks</h4>
                        <p class="text-slate-400 leading-relaxed">An outreach draft for every vendor with discernible risk, ranked by severity and citing that vendor's own drivers. Select one to compile and copy.</p>
                    </div>
                    <div class="bg-slate-900/60 p-4 rounded-lg border border-slate-700">
                        <h4 class="font-semibold text-amber-400 mb-1">Manage</h4>
                        <p class="text-slate-400 leading-relaxed">Add, edit, or delete entities. New nodes use the same VaR formula (<code class="text-slate-300">spend × score/100 × severity</code>, severity 0.6 without an internal record) and appear immediately across all views.</p>
                    </div>
                    <div class="bg-slate-900/60 p-4 rounded-lg border border-slate-700">
                        <h4 class="font-semibold text-cyan-400 mb-1">Documents</h4>
                        <p class="text-slate-400 leading-relaxed">Master Service Agreements and SOWs mapped to live graph nodes. Document upload &amp; RAG ingestion are coming soon.</p>
                    </div>
                </div>
            </div>

            <!-- Scoring model -->
            <div class="bg-slate-800 rounded-xl p-6 border border-slate-700">
                <h3 class="text-xs font-bold uppercase tracking-wider text-slate-300 mb-4">Risk Scoring Model</h3>
                <p class="text-xs text-slate-400 mb-4 leading-relaxed">Each vendor receives a composite risk score from 0 to 100, calculated as a weighted average of four dimensions. Higher scores indicate higher risk. All dimension scores are computed deterministically from live source data — the LLM writes the narrative summary but does not determine the scores.</p>

                <p class="text-[10px] text-slate-500 mb-2">Click a dimension to expand its scoring detail.</p>
                <div class="space-y-2 text-xs">

                    <!-- Financial -->
                    <details class="border border-slate-700 rounded-lg overflow-hidden" open>
                        <summary class="bg-slate-900/80 px-4 py-2 flex items-center justify-between cursor-pointer select-none">
                            <span class="font-semibold text-blue-400">Financial</span>
                            <span class="text-slate-400">30% of composite</span>
                        </summary>
                        <div class="p-4 space-y-2 text-slate-300">
                            <p><strong class="text-slate-200">Altman Z-Score</strong> — a multi-factor solvency model computed from yfinance data. Z &gt; 2.99 = Safe Zone; 1.81–2.99 = Grey Zone (elevated distress risk); Z &lt; 1.81 = Distress Zone (potential insolvency signal). Each band maps to a base financial score.</p>
                            <p><strong class="text-slate-200">Revenue Growth</strong> — year-on-year revenue change. Contraction of more than 5% adds a penalty; expansion above 10% provides a credit.</p>
                            <p><strong class="text-slate-200">Debt-to-Equity Ratio</strong> — measures financial leverage. Ratios above 150% indicate aggressive leverage and increase the score.</p>
                            <p><strong class="text-slate-200">Current Ratio</strong> — current assets divided by current liabilities. Ratios below 1.0 indicate short-term liquidity stress.</p>
                            <p class="text-slate-400 pt-1">Source: Yahoo Finance (yfinance). Each metric is cited with a direct link to the vendor's quote page, visible in the Vendor Inspector under Financial evidence.</p>
                        </div>
                    </details>

                    <!-- Operational -->
                    <details class="border border-slate-700 rounded-lg overflow-hidden">
                        <summary class="bg-slate-900/80 px-4 py-2 flex items-center justify-between cursor-pointer select-none">
                            <span class="font-semibold text-emerald-400">Operational</span>
                            <span class="text-slate-400">30% of composite</span>
                        </summary>
                        <div class="p-4 space-y-2 text-slate-300">
                            <p><strong class="text-slate-200">Spend Concentration</strong> — this vendor's contract value as a percentage of total portfolio spend. Concentration above 10% adds a penalty; above 20% adds a larger one.</p>
                            <p><strong class="text-slate-200">Single-Source Flag</strong> — vendors with no approved alternate supplier receive a significant score penalty. These vendors are also marked as candidate SPOFs.</p>
                            <p><strong class="text-slate-200">Business Continuity Plan (BCP)</strong> — whether a current BCP is on file. Absence adds a penalty.</p>
                            <p><strong class="text-slate-200">Audit Score</strong> — most recent internal audit result on a 0–100 scale. Scores below 70 add a penalty.</p>
                            <p class="text-slate-400 pt-1">Source: internal vendor registry (<code class="text-slate-300">data/synthetic/vendor_registry.json</code>). A vendor absent from the registry receives a default operational score of 50 with an explicit "no internal record" driver.</p>
                        </div>
                    </details>

                    <!-- Compliance -->
                    <details class="border border-slate-700 rounded-lg overflow-hidden">
                        <summary class="bg-slate-900/80 px-4 py-2 flex items-center justify-between cursor-pointer select-none">
                            <span class="font-semibold text-amber-400">Compliance</span>
                            <span class="text-slate-400">20% of composite</span>
                        </summary>
                        <div class="p-4 space-y-2 text-slate-300">
                            <p><strong class="text-slate-200">SEC Filing Status</strong> — for US-listed entities, the system fetches recent 10-K, 10-Q, and 8-K filings from SEC EDGAR. A current 10-K with no flags reduces the baseline score. 8-K filings within 90 days (e.g. material events, going concern disclosures, impairment notices) add a penalty per flag.</p>
                            <p><strong class="text-slate-200">Non-US-Listed Entities</strong> — vendors not listed on a US exchange (e.g. TSMC, Samsung, Foxconn, ASML) do not file with the SEC. These receive an explicit "No SEC filings — non-US-listed entity" driver with the EDGAR search URL attempted, and a fixed baseline score of 45. This reflects a data gap, not a compliance failure.</p>
                            <p><strong class="text-slate-200">Certification Gaps</strong> — missing ISO27001, SOC2, or equivalent certifications add incremental penalties.</p>
                            <p><strong class="text-slate-200">GDPR</strong> — absence of a signed Data Processing Agreement (DPA) adds a small penalty for vendors operating in or with EU entities.</p>
                            <p class="text-slate-400 pt-1">Source: SEC EDGAR full-text search API. Each filing is cited with a direct EDGAR document link, visible in the Vendor Inspector under Compliance evidence.</p>
                        </div>
                    </details>

                    <!-- Geopolitical -->
                    <details class="border border-slate-700 rounded-lg overflow-hidden">
                        <summary class="bg-slate-900/80 px-4 py-2 flex items-center justify-between cursor-pointer select-none">
                            <span class="font-semibold text-red-400">Geopolitical</span>
                            <span class="text-slate-400">20% of composite</span>
                        </summary>
                        <div class="p-4 space-y-2 text-slate-300">
                            <p><strong class="text-slate-200">Country Risk Index</strong> — a baseline score derived from the Basel AML Index, keyed by the vendor's headquarters country (ISO-2). Taiwan scores 45/100 (moderate exposure); South Korea 25/100 (low); United States 10/100 (low); China 65/100 (elevated). This baseline is always cited as the first geopolitical driver.</p>
                            <p><strong class="text-slate-200">Portfolio HHI Concentration</strong> — the Herfindahl-Hirschman Index measures geographic concentration of total supply spend. An HHI above 2500 indicates high concentration. The HHI contribution is cited per vendor, showing both the index value and the vendor's country's share of total spend (e.g. "TW accounts for 55.6% of supply spend"). This driver cross-links to the regional concentration chart in Risk Analysis.</p>
                            <p><strong class="text-slate-200">GDELT Event Signals</strong> — the system monitors the GDELT Project for recent trade-policy, sanctions, and supply-chain disruption events by country. Events are fetched once per country and shared across all vendors headquartered there.</p>
                            <p class="text-slate-400 pt-1">Source: Basel AML Index (country risk), GDELT Project (event signals). All geopolitical evidence is cited with source URLs, visible in the Vendor Inspector under Geopolitical evidence.</p>
                        </div>
                    </details>

                </div>
            </div>

            <!-- VaR methodology -->
            <div class="bg-slate-800 rounded-xl p-6 border border-slate-700">
                <h3 class="text-xs font-bold uppercase tracking-wider text-slate-300 mb-4">Value-at-Risk Methodology</h3>
                <p class="text-xs text-slate-400 mb-3 leading-relaxed">Each vendor's Value-at-Risk (VaR) represents the estimated financial exposure if that vendor were to experience a significant disruption. It is always less than or equal to the contract value for direct exposure, and may exceed it only where genuine cascade dependencies exist.</p>
                <div class="bg-slate-900 rounded-lg p-4 border border-slate-700 font-mono text-xs text-slate-300 space-y-1">
                    <p>p_disruption  =  composite_score / 100</p>
                    <p>severity      =  clamp(0.5 + 0.3 × single_source + 0.2 × no_alternate, 0, 1)</p>
                    <p>direct_VaR    =  contract_spend × p_disruption × severity   <span class="text-slate-500">← always ≤ contract_spend</span></p>
                    <p>cascade_VaR   =  Σ (child_spend × child_score/100 × dependency_strength)</p>
                    <p>VaR_total     =  direct_VaR + cascade_VaR</p>
                </div>
                <div class="mt-3 space-y-1 text-xs text-slate-400">
                    <p><strong class="text-slate-300">severity</strong> defaults to 0.6 when no internal vendor record exists (no single-source or alternate data available).</p>
                    <p><strong class="text-slate-300">cascade_VaR</strong> is zero for leaf nodes with no downstream dependents — a vendor with no mapped dependencies cannot propagate risk further.</p>
                    <p>The full decomposition of <code class="text-slate-300">direct_VaR</code>, <code class="text-slate-300">cascade_VaR</code>, and all intermediate values is recorded in <code class="text-slate-300">mathematical_lineage</code> on every node, accessible by clicking the node in the Network tab.</p>
                </div>
            </div>

            <!-- SPOF and HHI -->
            <div class="bg-slate-800 rounded-xl p-6 border border-slate-700">
                <h3 class="text-xs font-bold uppercase tracking-wider text-slate-300 mb-4">Single Points of Failure &amp; Concentration Metrics</h3>
                <div class="space-y-3 text-xs text-slate-400">
                    <p><strong class="text-slate-200">Single Point of Failure (SPOF)</strong> — a vendor is flagged as a SPOF if it is marked single-source in the internal registry and has at least one downstream dependent node in the supply chain graph. SPOFs are ringed in red in the Network graph and carry a badge in the Vendor Inspector. A supply chain with many SPOFs has limited resilience to individual vendor disruptions.</p>
                    <p><strong class="text-slate-200">Betweenness Centrality</strong> — a NetworkX graph metric measuring how often a node lies on the shortest path between other nodes. High centrality indicates a bottleneck — disrupting this vendor severs connections between many others. Shown in the Vendor Inspector under mathematical lineage.</p>
                    <p><strong class="text-slate-200">HHI (Herfindahl-Hirschman Index)</strong> — calculated as the sum of squared market share percentages across all vendor headquarters countries, using contract spend as the weight. An HHI below 1500 indicates a diversified portfolio; 1500–2500 is moderately concentrated; above 2500 is highly concentrated. A portfolio dominated by a single country (e.g. Taiwan at 55.6% of supply spend) produces a high HHI and represents a correlated geopolitical risk.</p>
                </div>
            </div>

            <!-- Data freshness -->
            <div class="bg-slate-800 rounded-xl p-6 border border-slate-700">
                <h3 class="text-xs font-bold uppercase tracking-wider text-slate-300 mb-3">Data Freshness</h3>
                <p class="text-xs text-slate-400 leading-relaxed">All source data is fetched at pipeline run time and timestamped per source. The data freshness panel (accessible from the top-right of the dashboard) shows when each data source was last retrieved and the composite score change for each vendor since the previous run. To refresh the data, re-run the pipeline: <code class="text-slate-300">python scripts/run_pipeline.py --company "Apple Inc" --backend mock</code>. The previous run's scores are cached to <code class="text-slate-300">data/cache/</code> and compared automatically on the next run.</p>
            </div>

        </div>
    </div>

    <script>
        let VIS_NODES_ARRAY = {{ vis_nodes_json }};
        let VIS_EDGES_ARRAY = {{ vis_edges_json }};
        let RISK_TABLE_DATA = {{ risk_table_json }};
        const GEOPOLITICAL_WEIGHTS = {{ chart_data_json }};
        const DATAROOM_DOCS = {{ dataroom_docs_json }};
        const PLAYBOOK_DATA = {{ playbooks_json }};
        const FRESHNESS_DATA = {{ freshness_json }};

        // ── B1 risk-scaled VaR (mirror of src/graph/cascading_risk.py) ──
        // direct_VaR = direct_spend * (composite/100) * severity, always <= direct_spend.
        // Manually-added nodes have no internal record (severity defaults to 0.6) and no
        // mapped upstream dependencies, so cascade_VaR = 0 and VaR_total = direct_VaR.
        function clamp(v, lo, hi) { return Math.max(lo, Math.min(hi, v)); }
        function computeManualVaR(spend, composite, singleSource, noAlternate, hasRecord) {
            const p = clamp(composite / 100, 0, 1);
            const severity = hasRecord
                ? clamp(0.5 + 0.3 * (singleSource ? 1 : 0) + 0.2 * (noAlternate ? 1 : 0), 0, 1)
                : 0.6;
            return spend * p * severity;  // cascade_VaR = 0 for manual leaf nodes
        }

        // ── B2 node sizing (mirror of _node_size_for_spend in html_generator.py) ──
        const NODE_MIN_SIZE = 18.0, NODE_MAX_SIZE = 60.0, NODE_SIZE_K = 0.00028;
        function nodeSizeForSpend(spend) {
            return Math.round(clamp(NODE_MIN_SIZE + NODE_SIZE_K * Math.sqrt(Math.max(spend, 0)),
                                    NODE_MIN_SIZE, NODE_MAX_SIZE) * 10) / 10;
        }

        let networkInstance = null;
        let nodesDataSet = new vis.DataSet();
        let edgesDataSet = new vis.DataSet();
        let editingNodeId = null; // CRUD update selection trace register

        const TAB_TITLES = {
            map: 'Network', analytics: 'Risk Analysis', playbook: 'Playbooks',
            dataroom: 'Documents', nodemgmt: 'Manage', readme: 'Guide'
        };
        const BASE_TITLE = document.title;
        function switchTab(name) {
            document.querySelectorAll('.tab-pane').forEach(p => p.classList.remove('active'));
            document.querySelectorAll('.tab-btn').forEach(b => b.classList.remove('active'));
            document.getElementById('tab-' + name).classList.add('active');
            // Activate the matching tab button by its switchTab('name') handler, so
            // navigation from a stat card (not just a tab click) highlights correctly.
            document.querySelectorAll('.tab-btn').forEach(b => {
                const h = b.getAttribute('onclick') || '';
                if (h.includes(`switchTab('${name}')`)) b.classList.add('active');
            });
            if (TAB_TITLES[name]) { document.title = `${BASE_TITLE} · ${TAB_TITLES[name]}`; }
            if (name === 'map') { renderLeftToRightNetwork(); }
            if (name === 'analytics') { renderExposureScatter(); }
        }

        // Shared "Coming Soon" notice for affordances not yet implemented
        // (document upload, file attach). A transient toast, not a dead control.
        function showComingSoon(feature) {
            const f = feature || 'This feature';
            let el = document.getElementById('coming-soon-toast');
            if (!el) {
                el = document.createElement('div');
                el.id = 'coming-soon-toast';
                el.className = 'fixed bottom-6 left-1/2 -translate-x-1/2 z-50 bg-slate-800 border border-blue-500/50 text-slate-100 text-sm px-5 py-3 rounded-xl shadow-2xl transition-opacity duration-300';
                document.body.appendChild(el);
            }
            el.innerHTML = `<span class="font-semibold text-blue-400">Coming Soon</span> — ${f} is not yet available in this build.`;
            el.style.opacity = '1';
            clearTimeout(el._t);
            el._t = setTimeout(() => { el.style.opacity = '0'; }, 2600);
        }

        // ── C3: stat cards carry context through to the view they open ──────────
        function _flashEl(el) {
            if (!el) return;
            el.classList.add('ring-2', 'ring-blue-400');
            setTimeout(() => el.classList.remove('ring-2', 'ring-blue-400'), 1600);
        }
        function cardOpenPortfolioValue() {
            switchTab('analytics');
            // Land sorted by contract value (impact axis).
            if (analyticsSort.key !== 'annual_spend_usd') sortAnalytics('annual_spend_usd');
            else showTransparencyConsole();
            const th = document.getElementById('th-contract-value');
            _flashEl(th);
            th?.scrollIntoView({ behavior: 'smooth', block: 'center' });
        }
        function cardOpenVaR() {
            switchTab('analytics');
            // Land sorted by exposure (VaR) descending.
            if (analyticsSort.key !== 'value_at_risk') sortAnalytics('value_at_risk');
            else showTransparencyConsole();
            const th = document.getElementById('th-exposure');
            _flashEl(th);
            th?.scrollIntoView({ behavior: 'smooth', block: 'center' });
        }
        function cardOpenHHI() {
            switchTab('analytics');
            const chart = document.getElementById('geo-distribution-container');
            chart?.scrollIntoView({ behavior: 'smooth', block: 'center' });
            _flashEl(chart);
        }
        function cardOpenNodes() {
            switchTab('map');
            // Briefly select-highlight all nodes in the network.
            setTimeout(() => {
                if (networkInstance) {
                    const ids = VIS_NODES_ARRAY.map(n => n.id);
                    try {
                        networkInstance.selectNodes(ids);
                        networkInstance.fit({ animation: { duration: 600 } });
                        setTimeout(() => networkInstance.unselectAll(), 1400);
                    } catch (e) { /* selection is best-effort */ }
                }
            }, 120);
        }

        // ── STABLE LEFT-TO-RIGHT HIERARCHY (vis.js hierarchical layout, physics off) ──
        // The hierarchical engine produces the Apple-center → suppliers-left →
        // customers/partners-right topology directly from edge direction
        // (sortMethod 'directed') and each node's tier `level`. No manual x/y math,
        // no physics — so the graph renders stable on load and a dragged node moves
        // alone with no ripple.
        // Map each node to a SIGNED hierarchical level so the LR layout is centered
        // on the target rather than left-anchored by raw depth:
        //   suppliers / partners / logistics  ->  negative level  (LEFT of target)
        //   target                            ->  level 0          (CENTER)
        //   customers / financial             ->  positive level   (RIGHT of target)
        // Tier (node.level: 1,2,3) sets the magnitude, so tier-2/3 push further out.
        const LEFT_GROUPS = new Set(['supplier', 'partner', 'logistics']);
        function layoutLevel(node) {
            const group = (node.group || '').toLowerCase();
            const tier = node.level || 0;           // raw depth: 0 target, 1/2/3 tiers
            if (group === 'target' || tier === 0) return 0;
            return LEFT_GROUPS.has(group) ? -tier : tier;
        }

        function renderLeftToRightNetwork() {
            const container = document.getElementById('network-container');
            nodesDataSet.clear();
            edgesDataSet.clear();

            // Layout-only copy: override `level` for hierarchical placement and apply
            // the visual encoding without mutating VIS_NODES_ARRAY (which the
            // table/scatter/inspector read by ref).
            //   size       ∝ √contract spend   (set in html_generator.py)
            //   ring colour = toned-down risk band  (<35 green / 35–64 amber / ≥65 red)
            //   ring width  ∝ exposure fraction (VaR / contract value)
            //   fill        = muted slate so colours never glare and labels stay legible
            //   SPOF        = dashed ring + ⚠ prefix, distinct from the risk ring
            const RISK_RING = (s) => s >= 65 ? '#b91c1c' : s >= 35 ? '#b45309' : '#15803d';
            const layoutNodes = VIS_NODES_ARRAY.map(n => {
                const ln = { ...n, level: layoutLevel(n) };
                const m = n.meta || {};
                // White label with a dark stroke reads on any background.
                ln.font = { color: '#f8fafc', size: 12, strokeWidth: 3, strokeColor: '#0f172a' };
                if (m.is_target) {
                    // Target (Apple) is not scored — neutral blue ring, no risk encoding.
                    ln.color = { background: '#1e293b', border: '#3b82f6',
                                 highlight: { background: '#1e293b', border: '#60a5fa' } };
                    ln.borderWidth = 3;
                    return ln;
                }
                const score = (m.score != null) ? m.score : 0;
                const spend = m.annual_spend_usd || 0;
                const exposureFrac = spend > 0 ? clamp((m.value_at_risk || 0) / spend, 0, 1) : 0;
                const ring = RISK_RING(score);
                ln.color = { background: '#1e293b', border: ring,
                             highlight: { background: '#334155', border: ring } };
                ln.borderWidth = Math.round(2 + 6 * exposureFrac);
                if (m.is_spof) {
                    ln.shapeProperties = { borderDashes: [4, 4] };
                    ln.borderWidth = Math.max(ln.borderWidth, 4);
                    ln.label = '⚠ ' + n.label;
                }
                return ln;
            });
            // Defense in depth: vis.DataSet.add() aborts the WHOLE batch on a
            // repeated id (silent — leaves a blank graph), so a single duplicate
            // upstream would erase every node. Keep the first node per id; a stray
            // duplicate can degrade the graph but can never blank it.
            const seenNodeIds = new Set();
            const uniqueLayoutNodes = layoutNodes.filter(n => {
                if (seenNodeIds.has(n.id)) {
                    console.warn('Dropping duplicate node id from render:', n.id);
                    return false;
                }
                seenNodeIds.add(n.id);
                return true;
            });
            nodesDataSet.add(uniqueLayoutNodes);
            // Edges reference node ids; silently drop any whose endpoints are
            // missing so a pruned/duplicate node can't break edge insertion.
            const validEdges = VIS_EDGES_ARRAY.filter(e => seenNodeIds.has(e.from) && seenNodeIds.has(e.to));
            edgesDataSet.add(validEdges);

            const dataset = { nodes: nodesDataSet, edges: edgesDataSet };
            const configuration = {
                nodes: { shape: 'dot', shadow: true, physics: false },
                edges: { smooth: { type: 'cubicBezier', forceDirection: 'horizontal', roundness: 0.4 }, arrows: "to" },
                layout: {
                    hierarchical: {
                        enabled: true,
                        direction: 'LR',
                        sortMethod: 'directed',
                        levelSeparation: 220,
                        nodeSpacing: 80,
                        treeSpacing: 150
                    }
                },
                physics: { enabled: false },
                interaction: { dragNodes: true, hover: true }
            };

            networkInstance = new vis.Network(container, dataset, configuration);
            // Hard post-init lock: ensure nothing downstream can re-enable physics.
            networkInstance.setOptions({ physics: false });

            networkInstance.on("click", function(params) {
                if (params.nodes.length > 0) { showInspector(params.nodes[0]); }
            });
        }

        // ── Render a DriverEvidence list as clickable source links (E3/F2/C2) ──
        function renderEvidenceLinks(evidence) {
            if (!evidence || evidence.length === 0) return '';
            return evidence.map(e => {
                const isAnchorLink = e.source_url && e.source_url.startsWith('#');
                const labelHtml = `${e.label}${e.value && !e.label.includes(e.value) ? ` <span class="text-slate-500">(${e.value})</span>` : ''}`;
                if (!e.source_url) {
                    return `<li class="text-slate-400 text-[10px] leading-snug">• ${labelHtml}</li>`;
                }
                if (isAnchorLink) {
                    // Cross-link into the analytics regional-concentration chart (F2).
                    return `<li class="text-[10px] leading-snug">• <a onclick="switchTab('analytics');document.querySelector('${e.source_url}')?.scrollIntoView({behavior:'smooth'});" class="text-blue-400 hover:underline cursor-pointer">${labelHtml} ↗</a></li>`;
                }
                return `<li class="text-[10px] leading-snug">• <a href="${e.source_url}" target="_blank" rel="noopener" class="text-blue-400 hover:underline break-words">${labelHtml} ↗</a></li>`;
            }).join('');
        }

        // ── Render one dimension block: score, weight, drivers, gaps, evidence (C1) ──
        function renderDimension(name, score, weight, drivers, gaps, evidence, colour) {
            const driverItems = (drivers || []).map(d => `<li class="leading-snug">• ${d}</li>`).join('')
                || '<li class="text-slate-500 italic">No drivers recorded.</li>';
            const gapItems = (gaps || []).length > 0
                ? `<div class="mt-1 text-amber-400/90 text-[10px]"><span class="uppercase font-semibold">Data gaps:</span><ul class="ml-2">${gaps.map(g => `<li class="leading-snug">⚠ ${g}</li>`).join('')}</ul></div>`
                : '';
            const evidenceItems = renderEvidenceLinks(evidence);
            const evidenceBlock = evidenceItems
                ? `<div class="mt-1"><span class="text-[9px] text-slate-500 uppercase">Sources:</span><ul class="ml-1">${evidenceItems}</ul></div>`
                : '';
            return `
                <div class="bg-slate-900 border border-slate-800 p-2 rounded text-[11px]">
                    <div class="flex justify-between items-baseline mb-1">
                        <span class="font-bold ${colour}">${name} <span class="text-slate-500 font-normal">(${weight}% weight)</span></span>
                        <strong class="text-slate-100">${score}/100</strong>
                    </div>
                    <ul class="text-slate-400 space-y-0.5">${driverItems}</ul>
                    ${gapItems}
                    ${evidenceBlock}
                </div>`;
        }

        // ── Narrative renderer: safe markdown → HTML (bold + bullets) ──
        // Hardens against stray markdown from any LLM backend so "**" never shows raw,
        // and renders the crisp Status / Key risks / Action format as clean HTML.
        function escapeHtml(s) {
            return String(s).replace(/[&<>]/g, c => ({ '&': '&amp;', '<': '&lt;', '>': '&gt;' }[c]));
        }
        function renderNarrative(text) {
            if (!text) return '';
            let t = escapeHtml(text).replace(/\*\*(.+?)\*\*/g, '<strong>$1</strong>');
            const lines = t.split(/\r?\n/);
            let html = '', inList = false;
            for (const raw of lines) {
                const line = raw.trim();
                if (!line) continue;
                if (/^[-•]\s+/.test(line)) {
                    if (!inList) { html += '<ul class="list-disc pl-4 my-1 space-y-0.5">'; inList = true; }
                    html += `<li>${line.replace(/^[-•]\s+/, '')}</li>`;
                } else {
                    if (inList) { html += '</ul>'; inList = false; }
                    const m = line.match(/^([A-Za-z ]{2,20}):\s*(.*)$/);
                    html += m
                        ? `<p class="my-1"><strong class="text-slate-200">${m[1]}:</strong> ${m[2]}</p>`
                        : `<p class="my-1">${line}</p>`;
                }
            }
            if (inList) html += '</ul>';
            return html;
        }

        // Wrap an extra inspector card (alternatives / cited sources) to match the
        // dimension cards so all six sit in one grid beneath the graph + narrative.
        function inspectorCard(title, colour, bodyHtml) {
            return `<div class="bg-slate-900 border border-slate-800 p-2 rounded text-[11px]">
                        <span class="font-bold ${colour} block mb-1">${title}</span>
                        ${bodyHtml}
                    </div>`;
        }

        function showInspector(id) {
            const node = VIS_NODES_ARRAY.find(n => n.id === id);
            if (!node) return;
            const m = node.meta;
            const w = m.weights || { fin: 30, ops: 30, comp: 20, geo: 20 };
            const isTarget = m.is_target;

            // ── Side panel: header + narrative only, at graph height ──
            document.getElementById('inspector-header').textContent =
                `${m.type} · ${m.industry} · ${m.country}`;
            const narrativeHtml = (m.narrative && m.narrative !== 'Baseline audit cycle complete.')
                ? renderNarrative(m.narrative)
                : '<p class="text-xs text-slate-500 italic">No narrative generated for this node.</p>';
            document.getElementById('inspector-narrative').innerHTML = `
                <div class="flex items-center gap-2 mb-2">
                    <h4 class="text-sm font-bold text-blue-400">${m.name}</h4>
                    ${m.is_spof ? '<span class="px-1.5 py-0.5 rounded text-[9px] font-bold bg-red-950 text-red-400 border border-red-900">⚠ SPOF</span>' : ''}
                </div>
                ${isTarget ? '<p class="text-[11px] text-slate-400 mb-2">Target entity — not scored.</p>' : `
                <div class="grid grid-cols-2 gap-2 text-xs mb-2">
                    <div class="bg-slate-900/60 p-2 rounded border border-slate-800">
                        <span class="text-[10px] text-slate-500 uppercase block">Composite Risk</span>
                        <strong class="text-sm font-bold text-white">${m.score} / 100</strong>
                    </div>
                    <div class="bg-slate-900/60 p-2 rounded border border-slate-800">
                        <span class="text-[10px] text-slate-500 uppercase block">Value-at-Risk</span>
                        <strong class="text-sm font-bold text-red-400">$${(m.value_at_risk||0).toLocaleString()}</strong>
                    </div>
                </div>`}
                <div class="text-[11px] leading-relaxed text-slate-300">
                    <span class="text-[9px] font-bold uppercase tracking-wider text-purple-400 block mb-1">AI Risk Narrative</span>
                    ${narrativeHtml}
                </div>
                ${isTarget ? '' : `<p class="text-[9px] text-slate-500 mt-2">Composite = Fin·${w.fin}% + Ops·${w.ops}% + Comp·${w.comp}% + Geo·${w.geo}%</p>`}
            `;

            // ── Six cards beneath the graph + narrative ──
            // C2: provenance anchors as clickable links, grouped by field key.
            const anchorEntries = Object.entries(m.provenance_anchors || {});
            const sourcesList = anchorEntries.length > 0
                ? anchorEntries.map(([key, a]) => {
                    const link = a.source_url
                        ? `<a href="${a.source_url}" target="_blank" rel="noopener" class="text-blue-400 hover:underline break-words">${a.label} ↗</a>`
                        : `<span class="text-slate-400">${a.label}</span>`;
                    return `<li class="mb-1"><span class="font-mono text-slate-500 text-[9px] uppercase block">${key}</span>${link}</li>`;
                }).join('')
                : '<li class="text-slate-500 italic">No source data fetched for this entity.</li>';

            // G2: ranked, justified pre-vetted alternatives.
            const backups = m.backups || [];
            const backupsBody = backups.length > 0
                ? `<ol class="space-y-1 list-decimal list-inside">${backups.map(b => `<li class="text-slate-200">${b.name}<span class="text-slate-400"> — ${b.justification || ''}</span></li>`).join('')}</ol>`
                : '<p class="text-slate-500 italic">No pre-vetted alternatives for this industry.</p>';

            document.getElementById('inspector-cards').innerHTML =
                  renderDimension('Financial', m.fin_score, w.fin, m.fin_drivers, m.fin_gaps, m.fin_evidence, 'text-blue-400')
                + renderDimension('Operational', m.ops_score, w.ops, m.ops_drivers, m.ops_gaps, [], 'text-emerald-400')
                + renderDimension('Compliance', m.comp_score, w.comp, m.comp_drivers, m.comp_gaps, m.comp_evidence, 'text-amber-400')
                + renderDimension('Geopolitical', m.geo_score, w.geo, m.geo_drivers, m.geo_gaps, m.geo_evidence, 'text-purple-400')
                + inspectorCard('Pre-vetted Alternatives', 'text-cyan-400', backupsBody)
                + inspectorCard('Cited Sources (provenance)', 'text-slate-300', `<ul>${sourcesList}</ul>`);
        }

        // Compact USD formatter for table cells ($22.0B, $1.1B, $850M ...).
        function fmtUSD(v) {
            v = Number(v) || 0;
            if (v >= 1e9) return '$' + (v / 1e9).toFixed(1) + 'B';
            if (v >= 1e6) return '$' + (v / 1e6).toFixed(1) + 'M';
            if (v >= 1e3) return '$' + (v / 1e3).toFixed(0) + 'K';
            return '$' + Math.round(v).toLocaleString();
        }

        // ── Three-band risk badge: <35 green, 35–64 amber, >=65 red ──
        // A vendor at 47/100 must read amber, never green.
        function riskBadgeClass(score) {
            if (score >= 65) return 'bg-red-950 text-red-400 border border-red-900';
            if (score >= 35) return 'bg-amber-950 text-amber-400 border border-amber-900';
            return 'bg-emerald-950 text-emerald-400 border border-emerald-900';
        }

        // ── score TRANSPARENCY CONSOLE MANAGEMENT ──
        let analyticsSort = { key: 'score', dir: -1 };  // default: highest composite first
        // Dropdown filters on the categorical columns (Category / HQ / Sector).
        let analyticsFilters = { type: '', country: '', industry: '' };

        function sortAnalytics(key) {
            if (analyticsSort.key === key) { analyticsSort.dir *= -1; }
            else { analyticsSort = { key, dir: (key === 'name' || key === 'type' || key === 'country' || key === 'industry') ? 1 : -1 }; }
            const k = analyticsSort.key, dir = analyticsSort.dir;
            RISK_TABLE_DATA.sort((a, b) => {
                let av = a[k], bv = b[k];
                if (typeof av === 'string') return dir * av.localeCompare(bv);
                return dir * ((av || 0) - (bv || 0));
            });
            showTransparencyConsole();
        }

        // Build the dropdown options from the distinct values present in the data.
        function populateAnalyticsFilters() {
            const cols = [['filter-type', 'type', 'All categories'],
                          ['filter-country', 'country', 'All HQs'],
                          ['filter-industry', 'industry', 'All sectors']];
            cols.forEach(([elId, key, allLabel]) => {
                const el = document.getElementById(elId);
                if (!el) return;
                const values = [...new Set(RISK_TABLE_DATA.map(r => r[key]).filter(Boolean))].sort();
                el.innerHTML = `<option value="">${allLabel}</option>`
                    + values.map(v => `<option value="${v}">${v}</option>`).join('');
            });
        }
        function applyAnalyticsFilters() {
            analyticsFilters = {
                type: document.getElementById('filter-type')?.value || '',
                country: document.getElementById('filter-country')?.value || '',
                industry: document.getElementById('filter-industry')?.value || '',
            };
            showTransparencyConsole();
        }
        function getFilteredRows() {
            return RISK_TABLE_DATA.filter(r =>
                (!analyticsFilters.type || r.type === analyticsFilters.type) &&
                (!analyticsFilters.country || r.country === analyticsFilters.country) &&
                (!analyticsFilters.industry || r.industry === analyticsFilters.industry));
        }

        function showTransparencyConsole() {
            const tbody = document.getElementById('analytics-table-body');
            const rows = getFilteredRows();
            if (rows.length === 0) {
                tbody.innerHTML = `<tr><td colspan="8" class="py-6 text-center text-slate-500 italic">No vendors match the selected filters.</td></tr>`;
            } else {
            tbody.innerHTML = rows.map(r => `
                <tr onclick="toggleTransparencyDropdown('${r.entity_id}')" class="hover:bg-slate-700/30 transition cursor-pointer border-b border-slate-800">
                    <td class="py-3 pl-2 font-medium text-white flex items-center gap-2"><span id="caret-${r.entity_id}" class="inline-block transition-transform text-slate-500">▶</span> <span class="text-blue-400 hover:underline">${r.name}</span></td>
                    <td class="py-3 uppercase font-mono text-[11px] text-slate-400">${r.type}</td>
                    <td class="py-3 font-mono text-slate-300">${r.country}</td>
                    <td class="py-3 text-slate-300">${r.industry || '—'}</td>
                    <td class="py-3"><span class="px-2 py-0.5 rounded text-[11px] font-bold ${riskBadgeClass(r.score)}">${r.score}</span></td>
                    <td class="py-3 text-right font-mono text-slate-300">${fmtUSD(r.annual_spend_usd)}</td>
                    <td class="py-3 text-right font-mono text-slate-400">${(r.dependence_pct ?? 0).toFixed(1)}%</td>
                    <td class="py-3 text-right pr-2 font-mono font-bold text-red-400">${fmtUSD(r.value_at_risk)}</td>
                </tr>
                <tr id="dropdown-${r.entity_id}" class="hidden bg-slate-900/50">
                    <td colspan="8" class="p-4">
                        ${(r.meta.narrative && r.meta.narrative !== 'Baseline audit cycle complete.')
                            ? `<div class="mb-3 bg-slate-950 border border-purple-900/40 rounded px-3 py-2 text-[11px] text-slate-300 leading-relaxed">
                                 <span class="text-[9px] font-bold uppercase tracking-wider text-purple-400 block mb-1">AI Risk Narrative</span>
                                 ${renderNarrative(r.meta.narrative)}
                               </div>`
                            : ''}
                        <div class="grid grid-cols-1 md:grid-cols-4 gap-4 text-xs">
                            <div class="bg-slate-900 border border-slate-800 p-3 rounded-lg">
                                <p class="font-bold text-blue-400 mb-1">Financial Data Core (${r.meta.fin_score}/100)</p>
                                <ul class="list-disc pl-4 space-y-1 text-slate-400 text-[11px]">${r.meta.fin_drivers.map(d => `<li>${d}</li>`).join('')}</ul>
                            </div>
                            <div class="bg-slate-900 border border-slate-800 p-3 rounded-lg">
                                <p class="font-bold text-emerald-400 mb-1">Operational Data Core (${r.meta.ops_score}/100)</p>
                                <ul class="list-disc pl-4 space-y-1 text-slate-400 text-[11px]">${r.meta.ops_drivers.map(d => `<li>${d}</li>`).join('')}</ul>
                            </div>
                            <div class="bg-slate-900 border border-slate-800 p-3 rounded-lg">
                                <p class="font-bold text-amber-400 mb-1">Compliance Scope (${r.meta.comp_score}/100)</p>
                                <ul class="list-disc pl-4 space-y-1 text-slate-400 text-[11px]">${(r.meta.comp_drivers||[]).map(d => `<li>${d}</li>`).join('') || '<li class="list-none text-slate-500 italic">No compliance drivers recorded.</li>'}</ul>
                            </div>
                            <div class="bg-slate-900 border border-slate-800 p-3 rounded-lg">
                                <p class="font-bold text-purple-400 mb-1">Geopolitical Scope (${r.meta.geo_score}/100)</p>
                                <ul class="list-disc pl-4 space-y-1 text-slate-400 text-[11px]">${(r.meta.geo_drivers||[]).map(d => `<li>${d}</li>`).join('') || '<li class="list-none text-slate-500 italic">No geopolitical drivers recorded.</li>'}</ul>
                            </div>
                        </div>
                    </td>
                </tr>
            `).join('');
            }

            const geoContainer = document.getElementById('geo-distribution-container');
            geoContainer.innerHTML = Object.entries(GEOPOLITICAL_WEIGHTS.geo_distribution).map(([country, percentage]) => `
                <div>
                    <div class="flex justify-between text-[11px] font-mono mb-0.5 text-slate-300">
                        <span><strong>${country}</strong></span>
                        <span>${percentage}%</span>
                    </div>
                    <div class="w-full bg-slate-900 h-1.5 rounded border border-slate-800 overflow-hidden">
                        <div class="bg-blue-500 h-full" style="width: ${percentage}%"></div>
                    </div>
                </div>
            `).join('');
        }

        // ── B4: impact × probability exposure scatter (Plotly) ──
        let scatterRendered = false;
        function renderExposureScatter() {
            const el = document.getElementById('exposure-scatter');
            if (!el || typeof Plotly === 'undefined') return;

            const rows = RISK_TABLE_DATA;
            const vars = rows.map(r => Number(r.value_at_risk) || 0);
            const maxVar = Math.max(1, ...vars);
            // Bubble area ∝ VaR; sqrt keeps small-VaR nodes visible.
            const sizes = vars.map(v => 12 + 44 * Math.sqrt(v / maxVar));

            const trace = {
                x: rows.map(r => r.score),
                y: rows.map(r => Number(r.annual_spend_usd) || 0),
                // Chart face shows the vendor name only; the full breakdown lives in
                // the hover tooltip (customdata) so the plot stays readable.
                text: rows.map(r => r.name),
                customdata: rows.map(r => [
                    r.score,
                    fmtUSD(r.annual_spend_usd),
                    (r.dependence_pct ?? 0).toFixed(1),
                    fmtUSD(r.value_at_risk),
                ]),
                mode: 'markers+text',
                type: 'scatter',
                textposition: 'top center',
                textfont: { color: '#cbd5e1', size: 9 },
                hovertemplate: '<b>%{text}</b><br>Composite: %{customdata[0]}/100'
                    + '<br>Contract: %{customdata[1]}'
                    + '<br>Dependence: %{customdata[2]}%'
                    + '<br>VaR: %{customdata[3]}<extra></extra>',
                marker: {
                    size: sizes,
                    color: vars,
                    colorscale: [[0, '#15803d'], [0.5, '#b45309'], [1, '#b91c1c']],
                    showscale: true,
                    colorbar: { title: { text: 'VaR', font: { color: '#94a3b8', size: 10 } },
                                tickfont: { color: '#94a3b8', size: 9 }, thickness: 10, len: 0.6 },
                    line: { color: '#0f172a', width: 1 },
                    opacity: 0.85,
                },
            };

            const layout = {
                paper_bgcolor: 'rgba(0,0,0,0)',
                plot_bgcolor: 'rgba(15,23,42,0.4)',
                margin: { l: 70, r: 20, t: 10, b: 50 },
                xaxis: { title: { text: 'Composite Risk Score  (probability of disruption →)', font: { color: '#94a3b8', size: 11 } },
                         color: '#94a3b8', gridcolor: 'rgba(100,116,139,0.15)', zeroline: false, range: [0, 100] },
                yaxis: { title: { text: 'Annual Contract Spend  (impact →)', font: { color: '#94a3b8', size: 11 } },
                         color: '#94a3b8', gridcolor: 'rgba(100,116,139,0.15)', zeroline: false, type: 'log' },
                showlegend: false,
            };

            Plotly.react(el, [trace], layout, { displayModeBar: false, responsive: true });
            scatterRendered = true;
        }

        function toggleTransparencyDropdown(id) {
            const expanded = !document.getElementById('dropdown-' + id).classList.toggle('hidden');
            const caret = document.getElementById('caret-' + id);
            if (caret) { caret.textContent = expanded ? '▼' : '▶'; }
        }

        // ── DATA FRESHNESS & CHANGE PANEL (static, real provenance timestamps) ──
        function renderFreshnessPanel() {
            const srcEl = document.getElementById('freshness-sources');
            if (FRESHNESS_DATA.sources && FRESHNESS_DATA.sources.length > 0) {
                srcEl.innerHTML = FRESHNESS_DATA.sources.map(s => `
                    <div class="flex justify-between items-center bg-slate-800 px-3 py-2 rounded border border-slate-700">
                        <span class="text-slate-200 font-medium">${s.source}</span>
                        <span class="text-slate-400 font-mono text-[11px]">${s.retrieved_at} <span class="text-slate-500">(${s.age})</span></span>
                    </div>
                `).join('');
            } else {
                srcEl.innerHTML = `<p class="text-slate-500 italic">No source retrieval timestamps recorded for this run.</p>`;
            }

            const deltaEl = document.getElementById('freshness-deltas');
            if (FRESHNESS_DATA.baseline) {
                deltaEl.innerHTML = `<p class="text-slate-400 italic">Baseline — no prior run cached. Future runs will show per-node composite movement here.</p>`;
            } else if (FRESHNESS_DATA.deltas && FRESHNESS_DATA.deltas.length > 0) {
                deltaEl.innerHTML = FRESHNESS_DATA.deltas.map(d => {
                    if (d.new) {
                        return `<div class="flex justify-between items-center bg-slate-800 px-3 py-2 rounded border border-slate-700">
                            <span class="text-slate-200">${d.name}</span>
                            <span class="text-blue-400 font-mono text-[11px]">NEW · ${d.current}</span></div>`;
                    }
                    const up = d.delta > 0;
                    const arrow = up ? '▲' : '▼';
                    const colour = up ? 'text-red-400' : 'text-emerald-400';
                    return `<div class="flex justify-between items-center bg-slate-800 px-3 py-2 rounded border border-slate-700">
                        <span class="text-slate-200">${d.name}</span>
                        <span class="${colour} font-mono text-[11px]">${arrow} ${Math.abs(d.delta)} → ${d.current}</span></div>`;
                }).join('');
            } else {
                deltaEl.innerHTML = `<p class="text-slate-400 italic">No composite score changes since the last cached run.</p>`;
            }
        }

        function openFreshnessPanel() {
            document.getElementById('freshness-modal').classList.remove('hidden');
        }

        // ── COMPREHENSIVE NODE MANIPULATION REGISTRY (ADD & INLINE EDIT CONSOLE) ──
        function renderNodeDirectory() {
            const tbody = document.getElementById('directory-table-body');
            tbody.innerHTML = VIS_NODES_ARRAY.map(n => `
                <tr class="hover:bg-slate-700/20 border-b border-slate-800/60">
                    <td class="py-2.5 font-medium text-white pl-2">${n.label}</td>
                    <td class="py-2.5 font-mono text-slate-400 text-[11px]">${n.id}</td>
                    <td class="py-2.5 uppercase text-slate-400 text-[10px]">${n.group || 'Supplier'}</td>
                    <td class="py-2.5 text-slate-300">${n.meta?.industry || 'General Operations'}</td>
                    <td class="py-2.5 font-mono text-slate-400">${n.meta?.country || 'US'}</td>
                    <td class="py-2.5 text-right pr-2 space-x-1">
                        <button onclick="initiateNodeEdit('${n.id}')" class="px-2.5 py-0.5 bg-amber-600/20 text-amber-400 border border-amber-500/30 rounded text-[11px] font-bold hover:bg-amber-600 hover:text-white transition">✏️ Edit</button>
                        ${n.meta?.is_target
                            ? '<span class="px-2.5 py-0.5 text-[10px] text-slate-600">target</span>'
                            : `<button onclick="deleteNode('${n.id}')" class="px-2.5 py-0.5 bg-red-600/20 text-red-400 border border-red-500/30 rounded text-[11px] font-bold hover:bg-red-600 hover:text-white transition">🗑 Delete</button>`}
                    </td>
                </tr>
            `).join('');

            const selector = document.getElementById('form-edge-target');
            selector.innerHTML = VIS_NODES_ARRAY.map(n => `<option value="${n.id}">${n.label} (${n.id})</option>`).join('');
        }

        // Remove a node and everything that references it, then re-render every view
        // so the graph, table, scatter, directory and filters stay consistent.
        function deleteNode(id) {
            const node = VIS_NODES_ARRAY.find(n => n.id === id);
            if (!node) return;
            if (node.meta && node.meta.is_target) {
                showComingSoon('Deleting the target entity');
                return;
            }
            if (!confirm(`Delete "${node.label}" and its dependency edges from this workspace?`)) return;

            // If the node being deleted is currently open in the edit form, reset it.
            if (editingNodeId === id) resetNodeForm();

            const dropIdx = VIS_NODES_ARRAY.findIndex(n => n.id === id);
            if (dropIdx !== -1) VIS_NODES_ARRAY.splice(dropIdx, 1);
            // Drop edges touching the node (either endpoint).
            for (let i = VIS_EDGES_ARRAY.length - 1; i >= 0; i--) {
                if (VIS_EDGES_ARRAY[i].from === id || VIS_EDGES_ARRAY[i].to === id) {
                    VIS_EDGES_ARRAY.splice(i, 1);
                }
            }
            // Drop its risk-register row.
            const rowIdx = RISK_TABLE_DATA.findIndex(r => r.entity_id === id);
            if (rowIdx !== -1) RISK_TABLE_DATA.splice(rowIdx, 1);

            renderLeftToRightNetwork();
            populateAnalyticsFilters();
            showTransparencyConsole();
            renderExposureScatter();
            renderNodeDirectory();
        }

        function initiateNodeEdit(id) {
            const node = VIS_NODES_ARRAY.find(n => n.id === id);
            if (!node) return;

            editingNodeId = id;
            document.getElementById('form-action-title').textContent = `✏️ Edit Workspace Entity: ${node.label}`;
            document.getElementById('form-submit-btn').textContent = "💾 Save Entity Modifications";
            document.getElementById('form-cancel-btn').classList.remove('hidden');
            document.getElementById('form-edge-container').classList.add('hidden'); // Lock relationships structure during properties updates

            // Map variables inside input fields
            document.getElementById('form-node-id').value = node.id;
            document.getElementById('form-node-id').disabled = true;
            document.getElementById('form-node-name').value = node.label;
            document.getElementById('form-node-type').value = node.group;
            document.getElementById('form-node-country').value = node.meta?.country || 'US';
            document.getElementById('form-node-industry').value = node.meta?.industry || 'General Operations';
            document.getElementById('form-node-importance').value = (node.meta?.importance ?? 5.0).toFixed(1);
            document.getElementById('form-node-spend').value = node.meta?.annual_spend_usd || 2500000;
        }

        function handleManualNodeSubmit(event) {
            event.preventDefault();
            const id = document.getElementById('form-node-id').value.trim();
            const name = document.getElementById('form-node-name').value.trim();
            const type = document.getElementById('form-node-type').value;
            const country = document.getElementById('form-node-country').value.trim().toUpperCase();
            const industry = document.getElementById('form-node-industry').value.trim();
            const importance = parseFloat(document.getElementById('form-node-importance').value);
            const spend = parseFloat(document.getElementById('form-node-spend').value);
            const targetEdge = document.getElementById('form-edge-target').value;

            if (editingNodeId) {
                // UPDATE RECORD MODE
                const targetNode = VIS_NODES_ARRAY.find(n => n.id === editingNodeId);
                if (targetNode) {
                    const composite = targetNode.meta.score || 45.0;
                    const varTotal = computeManualVaR(spend, composite, false, false, false);
                    targetNode.label = name;
                    targetNode.group = type;
                    targetNode.size = nodeSizeForSpend(spend);
                    targetNode.title = `Entity: ${name}\nType: ${type.toUpperCase()}\nHQ Region: ${country}\nRisk Score: ${composite}/100\nContract Spend: $${spend.toLocaleString()}\nValue-at-Risk: $${Math.round(varTotal).toLocaleString()}`;

                    targetNode.meta.name = name;
                    targetNode.meta.type = type;
                    targetNode.meta.country = country;
                    targetNode.meta.industry = industry;
                    targetNode.meta.annual_spend_usd = spend;
                    targetNode.meta.value_at_risk = varTotal;

                    const matchedTable = RISK_TABLE_DATA.find(r => r.entity_id === editingNodeId);
                    if (matchedTable) {
                        matchedTable.name = name;
                        matchedTable.type = type.toUpperCase();
                        matchedTable.country = country;
                        matchedTable.industry = industry;
                        matchedTable.annual_spend_usd = spend;
                        matchedTable.value_at_risk = varTotal;
                        matchedTable.meta = targetNode.meta;
                    }
                    populateAnalyticsFilters();
                }
                alert(`Node alterations successfully stored!`);
                resetNodeForm();
            } else {
                // INSERT NEW RECORD MODE
                if (VIS_NODES_ARRAY.some(n => n.id === id)) {
                    alert("An entity with this code prefix identifier already exists.");
                    return;
                }

                const composite = 45.0;
                const varTotal = computeManualVaR(spend, composite, false, false, false);
                const mockNode = {
                    id: id, label: name,
                    title: `Entity: ${name}\nType: ${type.toUpperCase()}\nHQ Region: ${country}\nRisk Score: ${composite}/100\nContract Spend: $${spend.toLocaleString()}\nValue-at-Risk: $${Math.round(varTotal).toLocaleString()}`,
                    color: { background: '#3b82f6', border: '#0f172a' },
                    size: nodeSizeForSpend(spend),
                    font: { color: '#f8fafc', size: 12 },
                    group: type, level: 1,
                    meta: {
                        entity_id: id, name: name, ticker: "—", type: type, industry: industry, country: country,
                        depth: 1, score: composite, risk_level: "medium", narrative: "Manually registered sourcing component asset.",
                        fin_score: 50.0, ops_score: 50.0, comp_score: 50.0, geo_score: 50.0,
                        annual_spend_usd: spend, value_at_risk: varTotal,
                        backups: [], fin_drivers: ["Manual data insertion baseline"], ops_drivers: ["Awaiting document execution audit"]
                    }
                };

                VIS_NODES_ARRAY.push(mockNode);
                VIS_EDGES_ARRAY.push({ from: id, to: targetEdge, label: "supplies_component", width: 2, color: { color: '#64748b' }, arrows: "to" });

                RISK_TABLE_DATA.push({
                    entity_id: id, name: name, ticker: "—", type: type.toUpperCase(), country: country,
                    industry: industry, score: composite, level: "medium", fin: 50.0, ops: 50.0, comp: 50.0, geo: 50.0,
                    annual_spend_usd: spend, dependence_pct: 0, value_at_risk: varTotal, meta: mockNode.meta
                });
                populateAnalyticsFilters();

                alert(`Node "${name}" successfully compiled and injected!`);
                document.getElementById('add-node-form').reset();
            }

            renderNodeDirectory();
            showTransparencyConsole();
            renderExposureScatter();
            switchTab('map');
        }

        function resetNodeForm() {
            editingNodeId = null;
            document.getElementById('form-action-title').textContent = "Add New Supply Chain Entity";
            document.getElementById('form-submit-btn').textContent = "➕ Inject Node Into Live Topography";
            document.getElementById('form-cancel-btn').classList.add('hidden');
            document.getElementById('form-edge-container').classList.remove('hidden');
            document.getElementById('form-node-id').disabled = false;
            document.getElementById('add-node-form').reset();
        }

        function renderPlaybooks() {
            const list = document.getElementById('playbook-trigger-list');
            if (!PLAYBOOK_DATA || PLAYBOOK_DATA.length === 0) {
                list.innerHTML = `<p class="text-xs text-slate-500 italic">No high-risk entities flagged in this run.</p>`;
                return;
            }
            list.innerHTML = PLAYBOOK_DATA.map(p => `
                <button id="playbook-btn-${p.id}" onclick="activatePlaybook(${p.id})" class="w-full text-left p-3 bg-slate-900 text-xs font-semibold rounded-lg border border-slate-700 hover:border-blue-500 hover:bg-slate-900/80 transition block text-slate-300">
                    ⚡ ${p.title}
                </button>
            `).join('');
            // Fix 4: auto-select the first playbook so the Outreach Generator shows
            // a real subject line and email body on load — no click required.
            activatePlaybook(PLAYBOOK_DATA[0].id);
        }

        function activatePlaybook(id) {
            const playbook = PLAYBOOK_DATA.find(p => p.id === id);
            if (!playbook) return;
            document.getElementById('comm-subject').textContent = playbook.subject;
            document.getElementById('comm-body').value = playbook.body;
            // Highlight the active playbook button.
            (PLAYBOOK_DATA || []).forEach(p => {
                const btn = document.getElementById('playbook-btn-' + p.id);
                if (btn) {
                    btn.classList.toggle('border-blue-500', p.id === id);
                    btn.classList.toggle('border-slate-700', p.id !== id);
                }
            });
        }

        function copyCommMessage() {
            navigator.clipboard.writeText(document.getElementById('comm-body').value);
            alert("Communications script copied to system clipboard memory!");
        }

        function renderDataRoom() {
            const el = document.getElementById('dataroom-list');
            if (!DATAROOM_DOCS || DATAROOM_DOCS.length === 0) {
                el.innerHTML = `<p class="text-xs text-slate-500 italic">No graph nodes available to illustrate document mapping.</p>`;
                return;
            }
            el.innerHTML = DATAROOM_DOCS.map(d => `
                <div class="flex justify-between items-center bg-slate-900 p-3 rounded-lg border border-slate-800 text-xs">
                    <div class="flex items-center gap-3">
                        <span class="text-lg">📄</span>
                        <div>
                            <p class="font-bold text-slate-200">${d.name}</p>
                            <p class="text-[10px] text-slate-400 mt-0.5">Classification Type: <strong>${d.type}</strong></p>
                        </div>
                    </div>
                    <div class="text-right">
                        <span class="px-2 py-0.5 rounded text-[10px] font-bold bg-slate-800 text-slate-400 border border-slate-700">Placeholder — not ingested</span>
                        <p class="text-[9px] text-slate-500 mt-1">Mapped to node: <span class="font-mono">${d.linked_node}</span> (${d.linked_name})</p>
                    </div>
                </div>
            `).join('');
        }

        window.onload = function() {
            renderLeftToRightNetwork();
            populateAnalyticsFilters();
            showTransparencyConsole();
            renderPlaybooks();
            renderDataRoom();
            renderNodeDirectory();
            renderFreshnessPanel();
        };
    </script>
</body>
</html>