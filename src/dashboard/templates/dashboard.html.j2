<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>Sentry Vendor Risk Intel Center - {{ target_company }}</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <script type="text/javascript" src="https://unpkg.com/vis-network/standalone/umd/vis-network.min.js"></script>
    <style>
        .tab-pane { display: none; }
        .tab-pane.active { display: block; }
        .tab-btn.active { background-color: #1e293b; border-color: #3b82f6; color: #3b82f6; }
        body { background-color: #0f172a; color: #f1f5f9; font-family: system-ui, -apple-system, sans-serif; }
    </style>
</head>
<body class="p-6">

    <div id="refresh-modal" class="fixed inset-0 bg-slate-950/80 backdrop-blur-sm z-50 hidden flex items-center justify-center">
        <div class="bg-slate-900 border border-slate-700 p-6 rounded-xl max-w-md w-full shadow-2xl">
            <div class="flex items-center gap-3 mb-4">
                <div class="animate-spin rounded-full h-5 w-5 border-2 border-blue-500 border-t-transparent"></div>
                <h3 class="font-bold text-white text-md">Agentic Fan-Out Pipeline Running</h3>
            </div>
            <div id="refresh-status-steps" class="space-y-2 text-xs font-mono text-slate-400">
                <p id="step-1" class="text-slate-500">⏳ [1/4] Watchlist Agent mapping deep structural graph vectors...</p>
                <p id="step-2" class="text-slate-500">⏳ [2/4] Footprint Agent connecting SEC EDGAR & yfinance endpoints...</p>
                <p id="step-3" class="text-slate-500">⏳ [3/4] Multi-Dimensional Risk scoring Engine re-computing matrices...</p>
                <p id="step-4" class="text-slate-500">⏳ [4/4] Generating finalized Executive report summary profiles...</p>
            </div>
        </div>
    </div>

    <div class="flex justify-between items-center mb-6 border-b border-slate-700 pb-4">
        <div>
            <h1 class="text-2xl font-bold tracking-tight text-white">🛡️ Sentry Vendor Risk Intelligence Studio</h1>
            <p class="text-xs text-slate-400">Target Ecosystem: <span class="font-semibold text-blue-400">{{ target_company }}</span> | Run: {{ run_id }} | Refreshed: <span id="generation-timestamp">{{ generated_at }}</span></p>
        </div>
        <div>
            <button onclick="triggerPipelineRefresh()" class="px-4 py-2 bg-gradient-to-r from-blue-600 to-indigo-600 hover:from-blue-500 hover:to-indigo-500 text-xs font-bold text-white rounded-lg shadow transition flex items-center gap-2">
                🔄 Trigger Footprint Refresh
            </button>
        </div>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-4 gap-4 mb-6">
        <div onclick="switchTab('analytics')" class="bg-slate-800 p-4 rounded-xl border border-slate-700 shadow-sm cursor-pointer hover:border-blue-500 transition group">
            <p class="text-xs text-slate-400 font-medium uppercase tracking-wider group-hover:text-blue-400 transition">Total Portfolio Value</p>
            <h3 class="text-xl font-bold text-white mt-1">${{ "{:,.2f}".format(stats.total_portfolio_value) }}</h3>
            <p class="text-[11px] text-slate-500 mt-0.5">Click to view aggregate expenditure data ↗</p>
        </div>
        <div onclick="switchTab('analytics')" class="bg-slate-800 p-4 rounded-xl border border-slate-700 shadow-sm cursor-pointer hover:border-red-500 transition group">
            <p class="text-xs text-slate-400 font-medium uppercase tracking-wider group-hover:text-red-400 transition">Portfolio Value-at-Risk</p>
            <h3 class="text-xl font-bold text-red-400 mt-1">${{ "{:,.2f}".format(stats.total_value_at_risk) }}</h3>
            <p class="text-[11px] text-red-500/80 mt-0.5">Click to analyze downstream cascade exposure ↗</p>
        </div>
        <div onclick="switchTab('analytics')" class="bg-slate-800 p-4 rounded-xl border border-slate-700 shadow-sm cursor-pointer hover:border-amber-500 transition group">
            <p class="text-xs text-slate-400 font-medium uppercase tracking-wider group-hover:text-amber-400 transition">Geopolitical HHI Score</p>
            <h3 class="text-xl font-bold text-amber-400 mt-1">{{ stats.geo_concentration_hhi }}</h3>
            <p class="text-[11px] text-slate-500 mt-0.5">Click to view regional asset distributions ↗</p>
        </div>
        <div onclick="switchTab('map')" class="bg-slate-800 p-4 rounded-xl border border-slate-700 shadow-sm cursor-pointer hover:border-indigo-500 transition group">
            <p class="text-xs text-slate-400 font-medium uppercase tracking-wider group-hover:text-indigo-400 transition">Supply Chain Nodes</p>
            <h3 class="text-xl font-bold text-white mt-1">{{ stats.total_entities }} Assets <span class="text-xs font-normal text-red-400">({{ stats.spof_count }} SPOFs)</span></h3>
            <p class="text-[11px] text-slate-500 mt-0.5">Click to inspect supply chain graph topology ↗</p>
        </div>
    </div>

    <div class="flex gap-2 mb-4 border-b border-slate-700 pb-px">
        <button class="tab-btn active px-4 py-2 text-sm font-semibold border-b-2 border-transparent text-slate-300 hover:text-white" onclick="switchTab('map')">🗺️ Supply Chain Map</button>
        <button class="tab-btn px-4 py-2 text-sm font-semibold border-b-2 border-transparent text-slate-300 hover:text-white" onclick="switchTab('analytics')">📊 Financial Impact & Scores</button>
        <button class="tab-btn px-4 py-2 text-sm font-semibold border-b-2 border-transparent text-slate-300 hover:text-white" onclick="switchTab('playbook')">⚡ Action Playbook & Comm Gen</button>
        <button class="tab-btn px-4 py-2 text-sm font-semibold border-b-2 border-transparent text-slate-300 hover:text-white" onclick="switchTab('dataroom')">🏢 Document Data Room</button>
        <button class="tab-btn px-4 py-2 text-sm font-semibold border-b-2 border-transparent text-slate-300 hover:text-white" onclick="switchTab('nodemgmt')">✏️ Node Management Registry</button>
        <button class="tab-btn px-4 py-2 text-sm font-semibold border-b-2 border-transparent text-blue-400 hover:text-blue-300 bg-blue-950/20 border border-blue-900 rounded-t-md" onclick="switchTab('readme')">📖 Platform User Guide</button>
    </div>

    <div id="tab-map" class="tab-pane active">
        <div class="grid grid-cols-1 lg:grid-cols-3 gap-4">
            <div class="lg:col-span-2 bg-slate-800 rounded-xl p-4 border border-slate-700 h-[580px]" id="network-container"></div>
            <div class="bg-slate-800 rounded-xl p-4 border border-slate-700 flex flex-col justify-between">
