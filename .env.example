# ── LLM Backend ───────────────────────────────────────────────────────────────
# Options: mock | ollama | vllm
LLM_BACKEND=mock

# ── vLLM (AMD MI300X) ─────────────────────────────────────────────────────────
VLLM_BASE_URL=http://localhost:8000/v1
VLLM_MODEL_NAME=Qwen/Qwen2.5-14B-Instruct-GPTQ-Int4

# ── Ollama (local alternative) ────────────────────────────────────────────────
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL_NAME=llama3.1:8b

# ── Public Data APIs ──────────────────────────────────────────────────────────
# NewsAPI — free tier: https://newsapi.org (optional, GDELT is used as fallback)
NEWS_API_KEY=your_newsapi_key_here

# SEC EDGAR — no key required, but set a user-agent string
SEC_USER_AGENT=VendorRiskIntel/1.0 your@email.com

# ── Pipeline Config ───────────────────────────────────────────────────────────
MAX_ENTITIES=80
MAX_DEPTH=3
MAX_CHILDREN_PER_NODE=7
CACHE_TTL_HOURS=24

# ── Output ────────────────────────────────────────────────────────────────────
OUTPUT_DIR=data/outputs
CACHE_DIR=data/cache
